{%- comment -%}
  Zaman Optics prescription workflow.
  This snippet is rendered from buy-buttons.liquid for prescription-mode products.
  It must own the product form so line item properties are submitted with the variant.
{%- endcomment -%}

{{ 'section-prescription.css' | asset_url | stylesheet_tag }}

<product-form
  class="product-form zpf-product-form"
  data-section-id="{{ section_id }}"
>
  <div class="product-form__error-message-wrapper" role="alert" hidden>
    <span class="svg-wrapper">
      {{- 'icon-error.svg' | inline_asset_content -}}
    </span>
    <span class="product-form__error-message"></span>
  </div>

  {%- form 'product',
    product,
    id: product_form_id,
    class: 'form zpf-form',
    novalidate: 'novalidate',
    data-type: 'add-to-cart-form'
  -%}
    <input
      type="hidden"
      name="id"
      value="{{ product.selected_or_first_available_variant.id }}"
      class="product-variant-id"
      {% if product.selected_or_first_available_variant.available == false %}
        disabled
      {% endif %}
    >

    <div
      class="zpf-wrapper"
      data-base="{{ product.selected_or_first_available_variant.price }}"
    >
      <div class="zpf-toggle-row" role="radiogroup" aria-label="Choose frame only or prescription lenses">
        <button
          type="button"
          class="zpf-toggle-btn zpf-toggle-active"
          data-zpf-mode="frame"
          aria-pressed="true"
        >
          <span class="zpf-toggle-icon" aria-hidden="true">Frame</span>
          <span class="zpf-toggle-text">
            <span class="zpf-toggle-title">Frame Only</span>
            <span class="zpf-toggle-sub">Order the frame without custom lenses</span>
          </span>
          <span class="zpf-toggle-tag">{{ product.selected_or_first_available_variant.price | money }}</span>
        </button>

        <button
          type="button"
          class="zpf-toggle-btn"
          data-zpf-mode="prescription"
          aria-pressed="false"
        >
          <span class="zpf-toggle-icon" aria-hidden="true">Rx</span>
          <span class="zpf-toggle-text">
            <span class="zpf-toggle-title">Add Prescription Lenses</span>
            <span class="zpf-toggle-sub">Choose lenses and share your prescription</span>
          </span>
          <span class="zpf-toggle-tag zpf-tag-accent">+ Rs 800</span>
        </button>
      </div>

      <input type="hidden" name="properties[Order Type]" id="zpfOrderType" value="Frame Only">
      <input type="hidden" name="properties[Lens Type]" id="zpfLensType" value="">
      <input type="hidden" name="properties[Lens Material]" id="zpfLensMaterial" value="">
      <input type="hidden" name="properties[Coatings]" id="zpfCoatings" value="">
      <input type="hidden" name="properties[Quoted Total Rs]" id="zpfTotalHidden" value="{{ product.selected_or_first_available_variant.price | divided_by: 100 }}">

      <div class="zpf-rx-panel" id="zpfRxPanel" aria-hidden="true">
        <div class="zpf-panel-block">
          <div class="zpf-block-title">
            Your Prescription
          </div>

          <div class="zpf-tab-row" role="tablist" aria-label="Prescription entry method">
            <button type="button" class="zpf-tab zpf-tab-on" data-zpf-tab="manual">
              Enter Manually
            </button>
            <button type="button" class="zpf-tab" data-zpf-tab="upload">
              Upload File
            </button>
          </div>

          <input type="hidden" name="properties[Prescription Method]" id="zpfRxMethod" value="Manual">

          <div id="zpfManual" class="zpf-tab-panel">
            <div class="zpf-hint-bar">
              Enter the values exactly as they appear on your prescription. If a field is blank, leave it blank or use 0.00 when required.
            </div>

            <div class="zpf-rx-grid">
              <div class="zpf-rx-grid-head">
                <div></div>
                <div>SPH</div>
                <div>CYL</div>
                <div>AXIS</div>
              </div>

              <div class="zpf-rx-grid-row">
                <div class="zpf-eye-cell">
                  <span class="zpf-eye-dot zpf-od">OD</span>
                  Right Eye
                </div>
                <div>
                  <input type="number" step="0.25" name="properties[Right Eye SPH]" placeholder="0.00" class="zpf-cell-input zpf-rx-required">
                </div>
                <div>
                  <input type="number" step="0.25" name="properties[Right Eye CYL]" placeholder="0.00" class="zpf-cell-input">
                </div>
                <div>
                  <input type="number" min="0" max="180" name="properties[Right Eye Axis]" placeholder="0" class="zpf-cell-input">
                </div>
              </div>

              <div class="zpf-rx-grid-row">
                <div class="zpf-eye-cell">
                  <span class="zpf-eye-dot zpf-os">OS</span>
                  Left Eye
                </div>
                <div>
                  <input type="number" step="0.25" name="properties[Left Eye SPH]" placeholder="0.00" class="zpf-cell-input zpf-rx-required">
                </div>
                <div>
                  <input type="number" step="0.25" name="properties[Left Eye CYL]" placeholder="0.00" class="zpf-cell-input">
                </div>
                <div>
                  <input type="number" min="0" max="180" name="properties[Left Eye Axis]" placeholder="0" class="zpf-cell-input">
                </div>
              </div>
            </div>

            <div class="zpf-pd-bar">
              <span class="zpf-pd-label">
                PD (Pupillary Distance)
                <span class="zpf-pd-hint">Usually 58-68mm</span>
              </span>
              <span class="zpf-pd-right">
                <input type="number" step="0.5" min="45" max="80" name="properties[PD]" placeholder="62.0" class="zpf-pd-input zpf-rx-required">
                <span class="zpf-pd-mm">mm</span>
              </span>
            </div>
          </div>

          <div id="zpfUpload" class="zpf-tab-panel" hidden>
            <label class="zpf-drop-zone" for="zpfFile-{{ section_id }}">
              <span class="zpf-drop-title">Upload your prescription</span>
              <span class="zpf-drop-hint">JPG, PNG, or PDF up to 5MB</span>
              <input
                type="file"
                id="zpfFile-{{ section_id }}"
                name="properties[Prescription File]"
                accept=".jpg,.jpeg,.png,.pdf"
                hidden
              >
            </label>
            <div id="zpfFilename" class="zpf-filename" hidden></div>
          </div>
        </div>

        <div class="zpf-panel-block">
          <div class="zpf-block-title">Lens Type</div>
          <div class="zpf-option-row">
            <label class="zpf-opt zpf-opt-on">
              <input type="radio" name="zpf_lens_type" value="Single Vision" data-fee="0" checked>
              <span class="zpf-opt-body">
                <span class="zpf-opt-name">Single Vision</span>
                <span class="zpf-opt-note">Distance or near correction</span>
              </span>
              <span class="zpf-opt-price">Included</span>
            </label>

            <label class="zpf-opt">
              <input type="radio" name="zpf_lens_type" value="Progressive" data-fee="120000">
              <span class="zpf-opt-body">
                <span class="zpf-opt-name">Progressive</span>
                <span class="zpf-opt-note">Distance and near correction</span>
              </span>
              <span class="zpf-opt-price zpf-accent">+ Rs 1,200</span>
            </label>

            <label class="zpf-opt">
              <input type="radio" name="zpf_lens_type" value="Bifocal" data-fee="80000">
              <span class="zpf-opt-body">
                <span class="zpf-opt-name">Bifocal</span>
                <span class="zpf-opt-note">Two focal points</span>
              </span>
              <span class="zpf-opt-price zpf-accent">+ Rs 800</span>
            </label>
          </div>
        </div>

        <div class="zpf-panel-block">
          <div class="zpf-block-title">Lens Material</div>
          <div class="zpf-material-grid">
            <label class="zpf-mat zpf-mat-on">
              <input type="radio" name="zpf_lens_material" value="Standard Plastic" data-fee="0" checked>
              <span class="zpf-mat-dot"></span>
              <span class="zpf-mat-body">
                <span class="zpf-mat-name">Standard Plastic</span>
                <span class="zpf-mat-note">Lightweight and affordable</span>
              </span>
              <span class="zpf-mat-p">Included</span>
            </label>

            <label class="zpf-mat">
              <input type="radio" name="zpf_lens_material" value="UV Protection" data-fee="60000">
              <span class="zpf-mat-dot"></span>
              <span class="zpf-mat-body">
                <span class="zpf-mat-name">UV Protection</span>
                <span class="zpf-mat-note">Blocks harmful UV rays</span>
              </span>
              <span class="zpf-mat-p zpf-accent">+ Rs 600</span>
            </label>

            <label class="zpf-mat">
              <input type="radio" name="zpf_lens_material" value="Blue Cut" data-fee="50000">
              <span class="zpf-mat-dot"></span>
              <span class="zpf-mat-body">
                <span class="zpf-mat-name">Blue Cut</span>
                <span class="zpf-mat-note">For screen-heavy use</span>
              </span>
              <span class="zpf-mat-p zpf-accent">+ Rs 500</span>
            </label>

            <label class="zpf-mat">
              <input type="radio" name="zpf_lens_material" value="Photochromic" data-fee="150000">
              <span class="zpf-mat-dot"></span>
              <span class="zpf-mat-body">
                <span class="zpf-mat-name">Photochromic</span>
                <span class="zpf-mat-note">Darkens outdoors</span>
              </span>
              <span class="zpf-mat-p zpf-accent">+ Rs 1,500</span>
            </label>
          </div>
        </div>

        <div class="zpf-panel-block">
          <div class="zpf-block-title">
            Add-on Coatings
            <span class="zpf-optional-tag">Optional</span>
          </div>
          <div class="zpf-coat-list">
            <label class="zpf-coat">
              <input type="checkbox" name="zpf_coatings" value="Anti-Glare" data-fee="30000" class="zpf-coat-cb">
              <span class="zpf-coat-box"></span>
              <span class="zpf-coat-body">
                <span class="zpf-coat-name">Anti-Glare</span>
                <span class="zpf-coat-note">Less reflections and better night comfort</span>
              </span>
              <span class="zpf-coat-p zpf-accent">+ Rs 300</span>
            </label>

            <label class="zpf-coat">
              <input type="checkbox" name="zpf_coatings" value="Anti-Scratch" data-fee="20000" class="zpf-coat-cb">
              <span class="zpf-coat-box"></span>
              <span class="zpf-coat-body">
                <span class="zpf-coat-name">Anti-Scratch</span>
                <span class="zpf-coat-note">Protects the lens surface</span>
              </span>
              <span class="zpf-coat-p zpf-accent">+ Rs 200</span>
            </label>

            <label class="zpf-coat">
              <input type="checkbox" name="zpf_coatings" value="Anti-Fog" data-fee="25000" class="zpf-coat-cb">
              <span class="zpf-coat-box"></span>
              <span class="zpf-coat-body">
                <span class="zpf-coat-name">Anti-Fog</span>
                <span class="zpf-coat-note">Helps reduce fogging</span>
              </span>
              <span class="zpf-coat-p zpf-accent">+ Rs 250</span>
            </label>
          </div>
        </div>
      </div>

      <div class="zpf-summary" id="zpfSummary" hidden>
        <div class="zpf-summary-rows" id="zpfSummaryRows"></div>
        <div class="zpf-summary-total">
          <span>Quoted Total</span>
          <span class="zpf-total-num" id="zpfTotal">
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
        </div>
        <p class="zpf-summary-note">
          Your selections are saved with the order so our team can review them before fulfillment.
        </p>
      </div>

      <div class="zpf-action-row">
        <button
          type="submit"
          name="add"
          class="zpf-btn-cart"
          {% if product.selected_or_first_available_variant.available == false %}
            disabled
          {% endif %}
        >
          <span>
            {%- if product.selected_or_first_available_variant.available == false -%}
              Sold Out
            {%- else -%}
              Add to Cart
            {%- endif -%}
          </span>
          {%- render 'loading-spinner' -%}
        </button>
        <button
          type="button"
          class="zpf-btn-buy"
          id="zpfBuyNow"
          {% if product.selected_or_first_available_variant.available == false %}
            disabled
          {% endif %}
        >
          <span>Buy Now</span>
        </button>
      </div>
    </div>
  {%- endform -%}
</product-form>

<script>
(() => {
  const root = document.currentScript.previousElementSibling;
  if (!root || root.dataset.zpfInitialized === 'true') return;
  root.dataset.zpfInitialized = 'true';

  const wrapper = root.querySelector('.zpf-wrapper');
  const form = root.querySelector('form');
  const base = parseInt(wrapper.dataset.base || '0', 10);
  let mode = 'frame';

  const money = (paisa) => {
    return 'Rs ' + Math.round(paisa / 100).toLocaleString('en-PK');
  };

  const row = (label, paisa) => {
    const amount = paisa === base ? money(paisa) : '+ ' + money(paisa);
    return '<div class="zpf-sum-row"><span>' + label + '</span><span>' + amount + '</span></div>';
  };

  const setRequired = () => {
    const manualActive = !root.querySelector('#zpfManual').hidden;
    root.querySelectorAll('.zpf-rx-required').forEach((input) => {
      if (mode === 'prescription' && manualActive) {
        input.setAttribute('required', 'required');
      } else {
        input.removeAttribute('required');
      }
    });
  };

  const syncProperties = (total) => {
    const lensType = root.querySelector('input[name="zpf_lens_type"]:checked');
    const lensMaterial = root.querySelector('input[name="zpf_lens_material"]:checked');
    const coatings = Array.from(root.querySelectorAll('input[name="zpf_coatings"]:checked')).map((input) => input.value);

    root.querySelector('#zpfOrderType').value = mode === 'prescription' ? 'With Prescription' : 'Frame Only';
    root.querySelector('#zpfLensType').value = mode === 'prescription' && lensType ? lensType.value : '';
    root.querySelector('#zpfLensMaterial').value = mode === 'prescription' && lensMaterial ? lensMaterial.value : '';
    root.querySelector('#zpfCoatings').value = mode === 'prescription' && coatings.length ? coatings.join(', ') : '';
    root.querySelector('#zpfTotalHidden').value = Math.round(total / 100);
  };

  const recalc = () => {
    let total = base;
    let rows = row('Frame', base);

    if (mode === 'prescription') {
      total += 80000;
      rows += row('Prescription Lenses', 80000);

      const lensType = root.querySelector('input[name="zpf_lens_type"]:checked');
      if (lensType) {
        const fee = parseInt(lensType.dataset.fee || '0', 10);
        if (fee > 0) {
          total += fee;
          rows += row(lensType.value, fee);
        }
      }

      const lensMaterial = root.querySelector('input[name="zpf_lens_material"]:checked');
      if (lensMaterial) {
        const fee = parseInt(lensMaterial.dataset.fee || '0', 10);
        if (fee > 0) {
          total += fee;
          rows += row(lensMaterial.value, fee);
        }
      }

      root.querySelectorAll('input[name="zpf_coatings"]:checked').forEach((input) => {
        const fee = parseInt(input.dataset.fee || '0', 10);
        total += fee;
        rows += row(input.value, fee);
      });
    }

    root.querySelector('#zpfSummaryRows').innerHTML = rows;
    root.querySelector('#zpfTotal').textContent = money(total);
    syncProperties(total);
    setRequired();
  };

  root.querySelectorAll('[data-zpf-mode]').forEach((button) => {
    button.addEventListener('click', () => {
      mode = button.dataset.zpfMode;
      root.querySelectorAll('[data-zpf-mode]').forEach((item) => {
        const isActive = item === button;
        item.classList.toggle('zpf-toggle-active', isActive);
        item.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      const isPrescription = mode === 'prescription';
      root.querySelector('#zpfRxPanel').classList.toggle('zpf-panel-open', isPrescription);
      root.querySelector('#zpfRxPanel').setAttribute('aria-hidden', isPrescription ? 'false' : 'true');
      root.querySelector('#zpfSummary').hidden = !isPrescription;
      recalc();
    });
  });

  root.querySelectorAll('[data-zpf-tab]').forEach((button) => {
    button.addEventListener('click', () => {
      const tab = button.dataset.zpfTab;
      root.querySelectorAll('[data-zpf-tab]').forEach((item) => {
        item.classList.toggle('zpf-tab-on', item === button);
      });
      root.querySelector('#zpfManual').hidden = tab !== 'manual';
      root.querySelector('#zpfUpload').hidden = tab !== 'upload';
      root.querySelector('#zpfRxMethod').value = tab === 'manual' ? 'Manual' : 'Upload';
      setRequired();
    });
  });

  root.querySelectorAll('input[name="zpf_lens_type"]').forEach((input) => {
    input.addEventListener('change', () => {
      root.querySelectorAll('.zpf-opt').forEach((item) => item.classList.remove('zpf-opt-on'));
      input.closest('.zpf-opt').classList.add('zpf-opt-on');
      recalc();
    });
  });

  root.querySelectorAll('input[name="zpf_lens_material"]').forEach((input) => {
    input.addEventListener('change', () => {
      root.querySelectorAll('.zpf-mat').forEach((item) => item.classList.remove('zpf-mat-on'));
      input.closest('.zpf-mat').classList.add('zpf-mat-on');
      recalc();
    });
  });

  root.querySelectorAll('input[name="zpf_coatings"]').forEach((input) => {
    input.addEventListener('change', () => {
      const item = input.closest('.zpf-coat');
      const box = item.querySelector('.zpf-coat-box');
      item.classList.toggle('zpf-coat-sel', input.checked);
      box.classList.toggle('zpf-coat-on', input.checked);
      recalc();
    });
  });

  const fileInput = root.querySelector('input[type="file"]');
  if (fileInput) {
    fileInput.addEventListener('change', () => {
      const filename = root.querySelector('#zpfFilename');
      if (fileInput.files && fileInput.files[0]) {
        filename.textContent = fileInput.files[0].name;
        filename.hidden = false;
      } else {
        filename.textContent = '';
        filename.hidden = true;
      }
    });
  }

  const buyNow = root.querySelector('#zpfBuyNow');
  if (buyNow) {
    buyNow.addEventListener('click', () => {
      if (!form.reportValidity()) return;
      const formData = new FormData(form);
      buyNow.setAttribute('disabled', 'disabled');

      fetch(window.routes.cart_add_url, {
        method: 'POST',
        body: formData,
        headers: {
          'X-Requested-With': 'XMLHttpRequest'
        }
      })
        .then((response) => response.json())
        .then((response) => {
          if (response.status) {
            const error = root.querySelector('.product-form__error-message-wrapper');
            const message = root.querySelector('.product-form__error-message');
            if (error && message) {
              message.textContent = response.description || 'Unable to add this product to cart.';
              error.hidden = false;
            }
            buyNow.removeAttribute('disabled');
            return;
          }
          window.location.href = '/checkout';
        })
        .catch(() => {
          buyNow.removeAttribute('disabled');
          form.requestSubmit();
        });
    });
  }

  recalc();
})();
</script>
