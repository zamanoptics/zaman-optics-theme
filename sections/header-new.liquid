<link rel="stylesheet" href="{{ 'section-header.css' | asset_url }}" media="print" onload="this.media='all'">

<header class="zaman-header">
  <!-- Top Announcement Bar -->
  <div class="zaman-header__announcement">
    <div class="page-width">
      <p>{{ section.settings.announcement_text | default: "Welcome to Zaman Optics!" }}</p>
    </div>
  </div>

  <!-- Main Header Row -->
  <div class="zaman-header__main">
    <div class="page-width">
      <div class="zaman-header__main-inner">
        <!-- Mobile Menu Toggle -->
        <button type="button" class="zaman-header__menu-toggle" id="MobileMenuToggle" aria-label="Toggle Menu">
          {% render 'zaman-premium-icon', icon: 'menu', size: 24 %}
        </button>

        <!-- Logo -->
        <div class="zaman-header__logo">
          <a href="/">
            {% if section.settings.logo != blank %}
              <img src="{{ section.settings.logo | img_url: 'master' }}" alt="{{ shop.name }}" width="150">
            {% else %}
              <h2>{{ shop.name }}</h2>
            {% endif %}
          </a>
        </div>
        
        <!-- Search -->
        <div class="zaman-header__search">
          <form action="/search" method="get" role="search">
            <input type="search" name="q" placeholder="Search for products...">
            <button type="submit">
              {% render 'zaman-premium-icon', icon: 'search', size: 20 %}
            </button>
          </form>
        </div>
        
        <!-- Icons -->
        <div class="zaman-header__icons">
          <a href="/account" aria-label="Account">
            {% render 'zaman-premium-icon', icon: 'account', size: 24 %}
          </a>
          <a href="/cart" aria-label="Cart">
            {% render 'zaman-premium-icon', icon: 'cart', size: 24 %}
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom Nav Bar -->
  <div class="zaman-header__nav">
    <div class="page-width">
      <nav class="zaman-desktop-nav">
        {% for link in linklists[section.settings.menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </nav>
    </div>
  </div>
</header>

<!-- Mobile Drawer -->
<div class="zaman-mobile-drawer" id="MobileDrawer">
  <div class="zaman-mobile-drawer__header">
    <h3>Menu</h3>
    <button type="button" class="zaman-mobile-drawer__close" id="MobileDrawerClose" aria-label="Close Menu">
      {% render 'zaman-premium-icon', icon: 'close', size: 24 %}
    </button>
  </div>
  <div class="zaman-mobile-drawer__content">
    <nav class="zaman-mobile-nav">
      {% for link in linklists[section.settings.menu].links %}
        <a href="{{ link.url }}">{{ link.title }}</a>
      {% endfor %}
    </nav>
  </div>
</div>
<div class="zaman-mobile-drawer-overlay" id="MobileDrawerOverlay"></div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var toggle = document.getElementById('MobileMenuToggle');
    var close = document.getElementById('MobileDrawerClose');
    var drawer = document.getElementById('MobileDrawer');
    var overlay = document.getElementById('MobileDrawerOverlay');

    function openDrawer() {
      drawer.classList.add('is-open');
      overlay.classList.add('is-open');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('is-open');
      overlay.classList.remove('is-open');
      document.body.style.overflow = '';
    }

    if (toggle) toggle.addEventListener('click', openDrawer);
    if (close) close.addEventListener('click', closeDrawer);
    if (overlay) overlay.addEventListener('click', closeDrawer);
  });
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "announcement_text",
      "label": "Announcement Text",
      "default": "Welcome to Zaman Optics!"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
