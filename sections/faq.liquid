<section class="zaman-faq-section">
  <div class="zaman-faq-inner">
    
    <div class="zaman-section-header">
      <span class="zaman-section-tag">
        {{ section.settings.tag_text }}
      </span>
      <h2 class="zaman-section-title">
        {{ section.settings.title }}
      </h2>
      <p class="zaman-section-subtitle">
        {{ section.settings.subtitle }}
      </p>
    </div>

    <div class="zaman-faq-grid">
      {% for block in section.blocks %}
      <details class="zaman-faq-item" 
               {{ block.shopify_attributes }}>
        <summary class="zaman-faq-question">
          <span>{{ block.settings.question }}</span>
          <span class="zaman-faq-icon">
            {% render 'zaman-premium-icon', icon: 'chevron-down', size: 20 %}
          </span>
        </summary>
        <div class="zaman-faq-answer">
          <p>{{ block.settings.answer }}</p>
        </div>
      </details>
      {% endfor %}
    </div>

    <div class="zaman-faq-cta">
      <p>{{ section.settings.cta_text }}</p>
      <a href="{{ section.settings.cta_url }}" 
         class="zaman-faq-cta-btn">
        {{ section.settings.cta_button }}
      </a>
    </div>

  </div>
</section>

<style>
.zaman-faq-section {
  padding: 80px 40px;
  background: #FFFFFF;
}
.zaman-faq-inner {
  max-width: 800px;
  margin: 0 auto;
}
.zaman-faq-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 48px;
}
.zaman-faq-item {
  background: #FAFAFA;
  border: 1.5px solid #F0F0F0;
  border-radius: 14px;
  overflow: hidden;
  transition: border-color 0.2s;
}
.zaman-faq-item[open] {
  border-color: #0F766E;
  background: #FFFFFF;
}
.zaman-faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16px;
  padding: 20px 24px;
  cursor: pointer;
  list-style: none;
  font-size: 15px;
  font-weight: 700;
  color: #1A1A1A;
  user-select: none;
}
.zaman-faq-question::-webkit-details-marker {
  display: none;
}
.zaman-faq-item[open] .zaman-faq-question {
  color: #0F766E;
  border-bottom: 1px solid #F0F0F0;
}
.zaman-faq-icon {
  flex-shrink: 0;
  width: 28px;
  height: 28px;
  background: #F0F0F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #666666;
  transition: all 0.2s;
}
.zaman-faq-item[open] .zaman-faq-icon {
  background: #0F766E;
  color: #FFFFFF;
  transform: rotate(180deg);
}
.zaman-faq-answer {
  padding: 0 24px 20px;
}
.zaman-faq-answer p {
  font-size: 14px;
  color: #666666;
  line-height: 1.75;
  margin: 16px 0 0 0;
}
.zaman-faq-cta {
  text-align: center;
  padding: 40px;
  background: #F8FAFC;
  border: 2px solid #D9F3EF;
  border-radius: 20px;
}
.zaman-faq-cta p {
  font-size: 16px;
  color: #555555;
  margin: 0 0 20px 0;
}
.zaman-faq-cta-btn {
  display: inline-block;
  padding: 13px 32px;
  background: #0F766E;
  color: #FFFFFF;
  border-radius: 50px;
  font-size: 14px;
  font-weight: 700;
  text-decoration: none;
  transition: all 0.2s;
}
.zaman-faq-cta-btn:hover {
  background: #0B5F59;
  transform: translateY(-2px);
  text-decoration: none;
  color: #FFFFFF;
}
@media (max-width: 768px) {
  .zaman-faq-section { padding: 48px 20px; }
  .zaman-faq-question { 
    padding: 16px 18px; 
    font-size: 14px; 
  }
}
</style>

{% schema %}
{
  "name": "FAQ",
  "settings": [
    {
      "type": "text",
      "id": "tag_text",
      "label": "Tag Label",
      "default": "FAQ"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Clear answers for choosing frames, lenses, prescriptions, and delivery."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Still have questions? Our team is here to help."
    },
    {
      "type": "text",
      "id": "cta_button",
      "label": "CTA Button Text",
      "default": "Contact Us"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button Link"
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How do I enter my prescription?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Choose prescription lenses on the product page and enter SPH, CYL, AXIS, and PD exactly as shown on your prescription. You can also upload a prescription file."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Section",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How do I enter my prescription?",
            "answer": "On the product page, choose prescription lenses and enter SPH, CYL, AXIS, and PD exactly as shown on your prescription. You can also upload a prescription file."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What payment methods are available?",
            "answer": "Available payment options are shown at checkout, including supported online payment methods enabled for your order."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does delivery take?",
            "answer": "Delivery timelines are shown during checkout and may vary by city, courier availability, and lens customization needs."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Can I return my glasses?",
            "answer": "Contact us as soon as possible if your order needs attention. Our team will review the issue and guide you on the available return, exchange, or correction options."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is PD (Pupillary Distance)?",
            "answer": "PD is the distance between the centers of your pupils, measured in millimeters. It helps align prescription lenses correctly with your eyes."
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "Do you make progressive lenses?",
            "answer": "Yes. Select the lens type on the product page and add your prescription details before adding the frame to cart."
          }
        }
      ]
    }
  ]
}
{% endschema %}
