{%- style -%}
  .category-nav {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E8E8E8;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .category-nav::-webkit-scrollbar {
    display: none;
  }

  .category-nav {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .category-nav__container {
    display: flex;
    gap: 0.75rem;
    padding: 1rem 1.5rem;
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    min-width: min-content;
  }
  .category-nav__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem 1.25rem;
    border: 1.5px solid #AFDCEC;
    border-radius: 20px;
    background-color: #FFFFFF;
    color: #1A1A1A;
    text-decoration: none;
    font-size: 0.8125rem;
    font-weight: 500;
    line-height: 1.4;
    transition: all 0.3s ease;
    white-space: nowrap;
    cursor: pointer;
  }

  .category-nav__link:hover {
    background-color: #AFDCEC;
    color: #1A1A1A;
    transform: translateY(-1px);
    box-shadow: 0 2px 8px rgba(175, 220, 236, 0.4);
  }

  .category-nav__link.active {
    background-color: #AFDCEC;
    color: #1A1A1A;
    font-weight: 600;
    border-color: #AFDCEC;
  }

  @media screen and (max-width: 749px) {
    .category-nav__container {
      padding: 0.75rem 1rem;
      gap: 0.5rem;
    }

    .category-nav__link {
      padding: 0.4rem 1rem;
      font-size: 0.75rem;
      border-radius: 18px;
    }
  }
{%- endstyle -%}

<nav class="category-nav" role="navigation" aria-label="Category Navigation">
  <div class="category-nav__container">
    <a href="/collections/eyeglasses?filter.p.m.custom.gender=Men" class="category-nav__link{% if collection.handle == 'eyeglasses' and request.query_string contains 'Men' %} active{% endif %}">
      Men Glasses
    </a>
    <a href="/collections/eyeglasses?filter.p.m.custom.gender=Women" class="category-nav__link{% if collection.handle == 'eyeglasses' and request.query_string contains 'Women' %} active{% endif %}">
      Women Glasses
    </a>
    <a href="/collections/blue-light-glasses" class="category-nav__link{% if collection.handle == 'blue-light-glasses' %} active{% endif %}">
      Blue Light Glasses
    </a>
    <a href="/collections/kids-glasses" class="category-nav__link{% if collection.handle == 'kids-glasses' %} active{% endif %}">
      Kids Glasses
    </a>
    <a href="/collections/sunglasses" class="category-nav__link{% if collection.handle == 'sunglasses' %} active{% endif %}">
      Sunglasses
    </a>
    <a href="/collections/contact-lenses" class="category-nav__link{% if collection.handle == 'contact-lenses' %} active{% endif %}">
      Contact Lenses
    </a>
    <a href="/collections/all?sort_by=created-descending" class="category-nav__link{% if collection.handle == 'all' and request.query_string contains 'created-descending' %} active{% endif %}">
      New Arrivals
    </a>
    <a href="/collections/all?sort_by=best-selling" class="category-nav__link{% if collection.handle == 'all' and request.query_string contains 'best-selling' %} active{% endif %}">
      Best Sellers
    </a>
  </div>
</nav>

{% schema %}
{
  "name": "Category Navigation",
  "settings": []
}
{% endschema %}
