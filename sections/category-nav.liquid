<nav class="category-nav" id="categoryNav">
  <div class="category-nav__container">
    <ul class="category-nav__list">
      <li><a href="/collections/all" class="category-nav__link active" data-category="all">All Products</a></li>
      <li><a href="/collections/men-frames" class="category-nav__link" data-category="men-frames">Men's Frames</a></li>
      <li><a href="/collections/women-frames" class="category-nav__link" data-category="women-frames">Women's Frames</a></li>
      <li><a href="/collections/blue-cut-lenses" class="category-nav__link" data-category="blue-cut-lenses">Blue Cut Lenses</a></li>
      <li><a href="/collections/progressive-lenses" class="category-nav__link" data-category="progressive-lenses">Progressive Lenses</a></li>
      <li><a href="/collections/accessories" class="category-nav__link" data-category="accessories">Accessories</a></li>
    </ul>
  </div>
</nav>

<style>
  .category-nav {
    background-color: #FFFFFF;
    border-bottom: 1px solid #E8E8E8;
    position: sticky;
    top: 64px; /* Below header */
    z-index: 10;
    width: 100%;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  .category-nav::-webkit-scrollbar {
    display: none; /* Safari and Chrome */
  }

  .category-nav__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .category-nav__list {
    display: flex;
    margin: 0;
    padding: 0;
    list-style: none;
    white-space: nowrap;
    gap: 32px;
  }

  .category-nav__link {
    display: flex;
    align-items: center;
    color: #1A1A1A;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    padding: 16px 0;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
  }

  .category-nav__link:hover {
    color: #AFDCEC;
  }

  .category-nav__link.active {
    color: #1A1A1A;
    border-bottom-color: #AFDCEC;
  }

  @media screen and (max-width: 749px) {
    .category-nav__container {
      padding: 0 16px;
    }
    .category-nav__list {
      gap: 24px;
    }
    .category-nav__link {
      font-size: 13px;
      padding: 12px 0;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const currentPath = window.location.pathname;
    const links = document.querySelectorAll('.category-nav__link');
    
    links.forEach(link => {
      // Remove active from all
      link.classList.remove('active');
      
      // Match path exactly to set active state
      if (link.getAttribute('href') === currentPath) {
        link.classList.add('active');
        
        // Scroll active item into view if off-screen
        link.scrollIntoView({ inline: 'center', block: 'nearest', behavior: 'smooth' });
      }
    });

    // Default to 'all products' if no exact match (optional)
    if (!document.querySelector('.category-nav__link.active')) {
      const defaultLink = document.querySelector('[data-category="all"]');
      if (defaultLink) defaultLink.classList.add('active');
    }
  });
</script>

