<section class="zaman-why-section">
  <div class="zaman-why-inner">
    
    <div class="zaman-section-header">
      <span class="zaman-section-tag">
        {{ section.settings.tag_text }}
      </span>
      <h2 class="zaman-section-title">
        {{ section.settings.title }}
      </h2>
      <p class="zaman-section-subtitle">
        {{ section.settings.subtitle }}
      </p>
    </div>

    <div class="zaman-why-grid">

      <div class="zaman-why-card">
        <div class="zaman-why-icon">{% render 'zaman-premium-icon', icon: 'lens', size: 30 %}</div>
        <h3>{{ section.settings.f1_title }}</h3>
        <p>{{ section.settings.f1_text }}</p>
      </div>

      <div class="zaman-why-card">
        <div class="zaman-why-icon">{% render 'zaman-premium-icon', icon: 'delivery', size: 30 %}</div>
        <h3>{{ section.settings.f2_title }}</h3>
        <p>{{ section.settings.f2_text }}</p>
      </div>

      <div class="zaman-why-card">
        <div class="zaman-why-icon">{% render 'zaman-premium-icon', icon: 'payment', size: 30 %}</div>
        <h3>{{ section.settings.f3_title }}</h3>
        <p>{{ section.settings.f3_text }}</p>
      </div>

      <div class="zaman-why-card">
        <div class="zaman-why-icon">{% render 'zaman-premium-icon', icon: 'return', size: 30 %}</div>
        <h3>{{ section.settings.f4_title }}</h3>
        <p>{{ section.settings.f4_text }}</p>
      </div>

      <div class="zaman-why-card">
        <div class="zaman-why-icon">{% render 'zaman-premium-icon', icon: 'glasses', size: 30 %}</div>
        <h3>{{ section.settings.f5_title }}</h3>
        <p>{{ section.settings.f5_text }}</p>
      </div>

      <div class="zaman-why-card">
        <div class="zaman-why-icon">{% render 'zaman-premium-icon', icon: 'star', size: 30 %}</div>
        <h3>{{ section.settings.f6_title }}</h3>
        <p>{{ section.settings.f6_text }}</p>
      </div>

    </div>

    <!-- Stats row -->
    <div class="zaman-stats-row">
      <div class="zaman-stat">
        <span class="zaman-stat-num">
          {{ section.settings.stat1_num }}
        </span>
        <span class="zaman-stat-label">
          {{ section.settings.stat1_label }}
        </span>
      </div>
      <div class="zaman-stat-divider"></div>
      <div class="zaman-stat">
        <span class="zaman-stat-num">
          {{ section.settings.stat2_num }}
        </span>
        <span class="zaman-stat-label">
          {{ section.settings.stat2_label }}
        </span>
      </div>
      <div class="zaman-stat-divider"></div>
      <div class="zaman-stat">
        <span class="zaman-stat-num">
          {{ section.settings.stat3_num }}
        </span>
        <span class="zaman-stat-label">
          {{ section.settings.stat3_label }}
        </span>
      </div>
      <div class="zaman-stat-divider"></div>
      <div class="zaman-stat">
        <span class="zaman-stat-num">
          {{ section.settings.stat4_num }}
        </span>
        <span class="zaman-stat-label">
          {{ section.settings.stat4_label }}
        </span>
      </div>
    </div>

  </div>
</section>

<style>
.zaman-why-section {
  padding: 80px 40px;
  background: #FAFAFA;
}
.zaman-why-inner {
  max-width: 1200px;
  margin: 0 auto;
}
.zaman-section-header {
  text-align: center;
  margin-bottom: 56px;
}
.zaman-section-tag {
  display: inline-block;
  padding: 6px 16px;
  background: #F0FDFA;
  color: #0F766E;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  border-radius: 50px;
  margin-bottom: 16px;
}
.zaman-section-title {
  font-size: 38px;
  font-weight: 900;
  color: #1A1A1A;
  letter-spacing: -0.5px;
  margin: 0 0 14px 0;
  line-height: 1.15;
}
.zaman-section-subtitle {
  font-size: 16px;
  color: #777777;
  max-width: 520px;
  margin: 0 auto;
  line-height: 1.7;
}
.zaman-why-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-bottom: 56px;
}
.zaman-why-card {
  background: #FFFFFF;
  border: 1.5px solid #F0F0F0;
  border-radius: 20px;
  padding: 32px 28px;
  transition: all 0.25s ease;
}
.zaman-why-card:hover {
  border-color: #0F766E;
  box-shadow: 0 8px 32px rgba(15,118,110,0.1);
  transform: translateY(-4px);
}
.zaman-why-icon {
  width: 54px;
  height: 54px;
  margin-bottom: 18px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #0F766E;
  background: #F0FDFA;
  border: 1px solid #D9F3EF;
  border-radius: 16px;
}
.zaman-why-card h3 {
  font-size: 16px;
  font-weight: 800;
  color: #1A1A1A;
  margin: 0 0 10px 0;
}
.zaman-why-card p {
  font-size: 14px;
  color: #777777;
  line-height: 1.65;
  margin: 0;
}
/* Stats Row */
.zaman-stats-row {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border: 1px solid #e8e8ed;
  border-radius: 20px;
  padding: 40px;
  gap: 0;
}
.zaman-stat {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.zaman-stat-num {
  font-size: 36px;
  font-weight: 900;
  color: #0F766E;
  letter-spacing: -1px;
}
.zaman-stat-label {
  font-size: 13px;
  color: #6e6e73;
  font-weight: 500;
}
.zaman-stat-divider {
  width: 1px;
  height: 50px;
  background: #e8e8ed;
  flex-shrink: 0;
}
@media (max-width: 900px) {
  .zaman-why-grid { 
    grid-template-columns: repeat(2, 1fr); 
  }
  .zaman-why-section { padding: 48px 20px; }
  .zaman-section-title { font-size: 28px; }
  .zaman-stats-row { 
    flex-wrap: wrap; 
    gap: 24px;
    padding: 32px 20px;
  }
  .zaman-stat-divider { display: none; }
}
@media (max-width: 540px) {
  .zaman-why-grid { 
    grid-template-columns: 1fr; 
  }
}
</style>

