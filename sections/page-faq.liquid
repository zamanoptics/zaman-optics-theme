{% comment %}
  FAQ Page Section
  Displays frequently asked questions with accordion functionality
{% endcomment %}

{{ 'page-faq.css' | asset_url | stylesheet_tag }}
{{ 'page-faq.js' | asset_url | script_tag }}

<div class="faq-page">
  <div class="faq-page__container">
    <header class="faq-page__header">
      <h1 class="faq-page__title">{{ page.title }}</h1>
      {% if page.content %}
        <div class="faq-page__intro">
          {{ page.content }}
        </div>
      {% endif %}
    </header>

    <!-- Delivery & Shipping -->
    <section class="faq-page__section">
      <h2 class="faq-page__section-title">Delivery & Shipping</h2>
      
      <div class="faq-accordion">
        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">How long does shipping take?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              We deliver across Pakistan, usually within 3-5 business days after prescription/order confirmation. Prescription lenses may take slightly longer because they are prepared to your exact values.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">Do you deliver outside Gujar Khan?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              Yes. We deliver outside Gujar Khan and across Pakistan through courier partners. Final delivery availability and charges are confirmed at checkout or through WhatsApp support.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">Is free shipping available?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              Free shipping is available on qualifying orders above Rs 3,000. If your location needs a special courier quote, our team will confirm before dispatch.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Prescription & Fit -->
    <section class="faq-page__section">
      <h2 class="faq-page__section-title">Prescription & Fit</h2>
      
      <div class="faq-accordion">
        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">What information do I need from my prescription?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              You'll need the following from your eyeglass prescription: OD/OS (right and left eye values), SPH (sphere), CYL (cylinder), AXIS, and PD (pupillary distance). These ensure we craft your glasses to your exact vision needs. Check our Prescription Guide page for detailed explanations of each value.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">How do I know what frame size fits me?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              Frame sizes are indicated by three measurements: lens width, bridge width, and temple length (e.g., 52-18-140). You can find your correct size by checking your current glasses, looking at your prescription card (which may have sizing info), or visiting our Size Guide page for detailed fitting instructions and face shape recommendations.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">Can you help me choose the right frame?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              Yes. Share your current glasses size, face photo, or preferred frame style on WhatsApp and our team can recommend frame shapes and sizes before you order.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Returns & Warranty -->
    <section class="faq-page__section">
      <h2 class="faq-page__section-title">Returns & Warranty</h2>
      
      <div class="faq-accordion">
        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">What is your return policy?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              We offer a 7-day return or replacement support window for eligible orders. Prescription lenses are custom-made, so our team reviews each case and helps fix fitting, lens, or fulfillment issues fairly.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">Do your glasses come with a warranty?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              Frames and lenses are checked before dispatch. Manufacturing defects are handled through replacement or repair support. Damage from misuse, accidents, or normal wear is not covered.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">What if I'm unhappy with my prescription?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              If your vision doesn't feel right with your new glasses, we recommend visiting your eye care professional to verify the prescription. If there's an error on our end, we'll replace your glasses at no charge. If your prescription from your doctor needs adjustment, you'll need a new prescription to reorder.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Payment & Discounts -->
    <section class="faq-page__section">
      <h2 class="faq-page__section-title">Payment & Promotions</h2>
      
      <div class="faq-accordion">
        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">What payment methods do you accept?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              We prioritize Cash on Delivery, EasyPaisa, JazzCash, and credit/debit cards where available. Payment options may vary by checkout and order confirmation method.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">Do you offer discounts for first-time buyers?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              Seasonal discounts and bundle offers may be available from time to time. Check the homepage announcement bar or contact us on WhatsApp for current offers.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">Can I use a discount code with other promotions?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              In most cases, discount codes cannot be combined with other active promotions. Our team can confirm the best available price before dispatch.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Lens Types & Features -->
    <section class="faq-page__section">
      <h2 class="faq-page__section-title">Lens Types & Features</h2>
      
      <div class="faq-accordion">
        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">What's the difference between single vision and progressive lenses?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              <strong>Single Vision</strong> lenses have one power throughout and correct vision at one distance. <strong>Progressive</strong> lenses have multiple powers in one lens (distance, intermediate, and reading) and are ideal for presbyopia (age-related vision changes). Progressive lenses offer seamless vision at all distances without visible lines.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">Should I choose blue light blocking lenses?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              Blue light blocking lenses reduce glare and filter blue light from digital screens, which can help reduce eye strain during extended screen time. They're great if you spend many hours on computers or phones. While not essential, many people notice improved comfort with blue light protection, especially in the evening.
            </p>
          </div>
        </div>

        <div class="faq-accordion__item">
          <button class="faq-accordion__trigger" aria-expanded="false">
            <span class="faq-accordion__question">What lens coating options are available?</span>
            <svg class="faq-accordion__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="faq-accordion__content" hidden>
            <p>
              We offer several premium coating options: anti-reflective coating (reduces glare), blue light filter, UV protection, scratch-resistant coating, and photochromic coating (darkens in sunlight). You can combine multiple coatings to customize your lenses. Visit our Lens Guide page for detailed information about each option.
            </p>
          </div>
        </div>
      </div>
    </section>
  </div>
</div>
