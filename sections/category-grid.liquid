{{ 'section-category-grid.css' | asset_url | stylesheet_tag }}

<div class="category-grid-section">
  <h2 class="category-grid-title">Shop by Category</h2>
  <div class="category-grid">
    
    <a href="/collections/eyeglasses" class="cat-card">
      <div class="cat-card-image">
        {% if section.settings.eyeglasses_image %}
          <img src="{{ section.settings.eyeglasses_image | img_url: '400x400' }}" 
               alt="Eyeglasses">
        {% else %}
          <div class="cat-card-placeholder">{% render 'zaman-premium-icon', icon: 'glasses', size: 42 %}</div>
        {% endif %}
      </div>
      <div class="cat-card-body">
        <h3 class="cat-card-title">Eyeglasses</h3>
        <p class="cat-card-sub">Everyday optical frames</p>
        <span class="cat-card-link">Explore</span>
      </div>
    </a>

    <a href="/collections/sunglasses" class="cat-card">
      <div class="cat-card-image">
        {% if section.settings.sunglasses_image %}
          <img src="{{ section.settings.sunglasses_image | img_url: '400x400' }}" 
               alt="Sunglasses">
        {% else %}
          <div class="cat-card-placeholder">{% render 'zaman-premium-icon', icon: 'sunglasses', size: 42 %}</div>
        {% endif %}
      </div>
      <div class="cat-card-body">
        <h3 class="cat-card-title">Sunglasses</h3>
        <p class="cat-card-sub">Sun-ready styles</p>
        <span class="cat-card-link">Explore</span>
      </div>
    </a>

    <a href="/collections/blue-light-glasses" class="cat-card">
      <div class="cat-card-image">
        {% if section.settings.bluelight_image %}
          <img src="{{ section.settings.bluelight_image | img_url: '400x400' }}" 
               alt="Blue Light Glasses">
        {% else %}
          <div class="cat-card-placeholder">{% render 'zaman-premium-icon', icon: 'screen', size: 42 %}</div>
        {% endif %}
      </div>
      <div class="cat-card-body">
        <h3 class="cat-card-title">Blue Light Glasses</h3>
        <p class="cat-card-sub">Comfort for screen time</p>
        <span class="cat-card-link">Explore</span>
      </div>
    </a>

    <a href="/collections/kids-glasses" class="cat-card">
      <div class="cat-card-image">
        {% if section.settings.kids_image %}
          <img src="{{ section.settings.kids_image | img_url: '400x400' }}" 
               alt="Kids Glasses">
        {% else %}
          <div class="cat-card-placeholder">{% render 'zaman-premium-icon', icon: 'kids', size: 42 %}</div>
        {% endif %}
      </div>
      <div class="cat-card-body">
        <h3 class="cat-card-title">Kids Glasses</h3>
        <p class="cat-card-sub">Lightweight kids frames</p>
        <span class="cat-card-link">Explore</span>
      </div>
    </a>

    <a href="/collections/all?sort_by=created-descending" class="cat-card">
      <div class="cat-card-image">
        {% if section.settings.new_image %}
          <img src="{{ section.settings.new_image | img_url: '400x400' }}" 
               alt="New Arrivals">
        {% else %}
          <div class="cat-card-placeholder">{% render 'zaman-premium-icon', icon: 'sparkle', size: 42 %}</div>
        {% endif %}
      </div>
      <div class="cat-card-body">
        <h3 class="cat-card-title">New Arrivals</h3>
        <p class="cat-card-sub">Fresh styles</p>
        <span class="cat-card-link">Explore</span>
      </div>
    </a>

    <a href="/collections/all?sort_by=best-selling" class="cat-card">
      <div class="cat-card-image">
        {% if section.settings.bestsellers_image %}
          <img src="{{ section.settings.bestsellers_image | img_url: '400x400' }}" 
               alt="Best Sellers">
        {% else %}
          <div class="cat-card-placeholder">{% render 'zaman-premium-icon', icon: 'star', size: 42 %}</div>
        {% endif %}
      </div>
      <div class="cat-card-body">
        <h3 class="cat-card-title">Best Sellers</h3>
        <p class="cat-card-sub">Customer favorites</p>
        <span class="cat-card-link">Explore</span>
      </div>
    </a>

  </div>
</div>

{% schema %}
{
  "name": "Category Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "eyeglasses_image",
      "label": "Eyeglasses Image"
    },
    {
      "type": "image_picker",
      "id": "sunglasses_image",
      "label": "Sunglasses Image"
    },
    {
      "type": "image_picker",
      "id": "bluelight_image",
      "label": "Blue Light Image"
    },
    {
      "type": "image_picker",
      "id": "kids_image",
      "label": "Kids Glasses Image"
    },
    {
      "type": "image_picker",
      "id": "new_image",
      "label": "New Arrivals Image"
    },
    {
      "type": "image_picker",
      "id": "bestsellers_image",
      "label": "Best Sellers Image"
    }
  ],
  "presets": [
    {
      "name": "Shop by Category"
    }
  ]
}
{% endschema %}
