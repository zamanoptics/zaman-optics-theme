          }
        },
        {
          "type": "review",
          "settings": {
            "quote": "Good sunglasses selection and the product photos made it easy to choose. The team helped me pick the right size before shipping.",
            "name": "Sana M.",
            "meta": "Sunglasses"
          }
        }
      ]
    }
  ]
}
{% endschema %}
