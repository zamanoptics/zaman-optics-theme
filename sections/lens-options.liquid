<section class="zo-lens-options">
  <div class="zo-lens-options__inner">
    <div class="zo-section-head">
      <span>{{ section.settings.kicker }}</span>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.subtitle }}</p>
    </div>

    <div class="zo-lens-options__grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link }}" class="zo-lens-card" {{ block.shopify_attributes }}>
          <span class="zo-lens-card__label">{{ block.settings.label }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .zo-lens-options {
    padding: clamp(64px, 8vw, 112px) 24px;
    background: #ffffff;
  }

  .zo-lens-options__inner {
    width: min(100%, 1480px);
    margin: 0 auto;
  }

  .zo-section-head {
    max-width: 680px;
    margin-bottom: 36px;
  }

  .zo-section-head span {
    color: #6e6e73;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .zo-section-head h2 {
    margin: 10px 0 12px;
    color: #1d1d1f;
    font-size: clamp(36px, 4vw, 56px);
    line-height: 1.04;
    font-weight: 800;
  }

  .zo-section-head p {
    margin: 0;
    color: #6e6e73;
    font-size: 18px;
    line-height: 1.6;
  }

  .zo-lens-options__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 18px;
  }

  .zo-lens-card {
    min-height: 260px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 26px;
    border: 1px solid #e8e8ed;
    border-radius: 22px;
    background: #f5f5f7;
    color: #1d1d1f;
    text-decoration: none;
    transition: border-color 160ms ease, transform 160ms ease, box-shadow 160ms ease;
  }

  .zo-lens-card:hover {
    border-color: #d2d2d7;
    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.05);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .zo-lens-card__label {
    color: #0F766E;
    font-size: 13px;
    font-weight: 700;
    margin-bottom: auto;
  }

  .zo-lens-card h3 {
    margin: 28px 0 10px;
    font-size: 24px;
    line-height: 1.12;
    font-weight: 760;
  }

  .zo-lens-card p {
    margin: 0;
    color: #6e6e73;
    line-height: 1.55;
  }

  @media (max-width: 990px) {
    .zo-lens-options__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 560px) {
    .zo-lens-options__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Lens Options",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Lens options"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Choose the right lens for daily life."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Help customers understand upgrades before they reach the product page."
    }
  ],
  "blocks": [
    {
      "type": "lens",
      "name": "Lens card",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Included"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Single Vision"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "For distance, reading, or everyday prescription needs."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lens Options",
      "blocks": [
        {
          "type": "lens",
          "settings": {
            "label": "Included",
            "title": "Single Vision",
            "text": "For one prescription power, distance or near."
          }
        },
        {
          "type": "lens",
          "settings": {
            "label": "+ Rs 1,200",
            "title": "Progressive",
            "text": "Distance, intermediate, and reading in one lens."
          }
        },
        {
          "type": "lens",
          "settings": {
            "label": "+ Rs 500",
            "title": "Blue Cut",
            "text": "Comfort for phones, laptops, and long screen hours."
          }
        },
        {
          "type": "lens",
          "settings": {
            "label": "+ Rs 1,500",
            "title": "Photochromic",
            "text": "Clear indoors and darker outdoors in sunlight."
          }
        }
      ]
    }
  ]
}
{% endschema %}
