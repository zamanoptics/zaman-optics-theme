{{ 'section-trust-features.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .trust-features-section {
    background-color: #F5F5F5;
    padding: 60px 2rem;
  }

  .trust-features-section__title {
    text-align: center;
    font-size: 1.75rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 3.5rem 0;
    letter-spacing: -0.01em;
  }

  .trust-features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .trust-feature-card {
    background-color: #FFFFFF;
    border: 1px solid #E8E8ED;
    border-radius: 16px;
    padding: 2.5rem 1.5rem;
    text-align: center;
    box-shadow: none;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .trust-feature-card__icon {
    width: 56px;
    height: 56px;
    margin-bottom: 1.5rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #0F766E;
    background: #F0FDFA;
    border: 1px solid #D9F3EF;
    border-radius: 18px;
  }

  .trust-feature-card__title {
    font-size: 1rem;
    font-weight: 700;
    color: #1A1A1A;
    margin: 0 0 0.75rem 0;
    line-height: 1.4;
  }

  .trust-feature-card__description {
    font-size: 0.875rem;
    color: #666666;
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 989px) and (min-width: 750px) {
    .trust-features-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }

    .trust-features-section {
      padding: 50px 1.5rem;
    }
  }

  @media screen and (max-width: 749px) {
    .trust-features-grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
    }

    .trust-features-section {
      padding: 40px 1rem;
    }

    .trust-feature-card {
      padding: 1.75rem 1.25rem;
    }

    .trust-feature-card__icon {
      width: 50px;
      height: 50px;
      margin-bottom: 1rem;
    }
  }
{%- endstyle -%}

<div class="trust-features-section">
  <h2 class="trust-features-section__title">{{ section.settings.section_title }}</h2>

  <div class="trust-features-grid">
    {%- for block in section.blocks -%}
      <div class="trust-feature-card" {{ block.shopify_attributes }}>
        <span class="trust-feature-card__icon">
          {% render 'zaman-premium-icon', icon: block.settings.premium_icon, size: 28 %}
        </span>
        <h3 class="trust-feature-card__title">{{ block.settings.title }}</h3>
        <p class="trust-feature-card__description">{{ block.settings.description }}</p>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Why Choose Us",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Why Choose Zaman Optics?"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Trust Feature Card",
      "limit": 4,
      "settings": [
        {
          "type": "select",
          "id": "premium_icon",
          "label": "Icon",
          "default": "lens",
          "options": [
            { "value": "lens", "label": "Prescription lens" },
            { "value": "delivery", "label": "Delivery" },
            { "value": "payment", "label": "Payment" },
            { "value": "return", "label": "Returns" },
            { "value": "glasses", "label": "Glasses" },
            { "value": "star", "label": "Star rating" },
            { "value": "shield", "label": "Quality shield" },
            { "value": "ruler", "label": "Fit guide" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Feature description goes here"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why Choose Us",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "premium_icon": "lens",
            "title": "Prescription Support",
            "description": "Enter your details online or upload a prescription file for review before fulfillment."
          }
        },
        {
          "type": "feature",
          "settings": {
            "premium_icon": "delivery",
            "title": "Pakistan Delivery",
            "description": "Orders are packed with care and delivered through trusted local courier partners."
          }
        },
        {
          "type": "feature",
          "settings": {
            "premium_icon": "payment",
            "title": "Clear Checkout",
            "description": "Available payment options are shown securely at checkout before you place the order."
          }
        },
        {
          "type": "feature",
          "settings": {
            "premium_icon": "return",
            "title": "Helpful Aftercare",
            "description": "If something needs attention after delivery, contact our team and we will guide the next step."
          }
        }
      ]
    }
  ]
}
{% endschema %}
