<section class="zo-shop-guide">
  <div class="zo-shop-guide__inner">
    <div class="zo-section-head zo-section-head--center">
      <span>{{ section.settings.kicker }}</span>
      <h2>{{ section.settings.title }}</h2>
      <p>{{ section.settings.subtitle }}</p>
    </div>

    <div class="zo-shop-guide__steps">
      {% for block in section.blocks %}
        <article class="zo-guide-step" {{ block.shopify_attributes }}>
          <span>{{ forloop.index }}</span>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  .zo-shop-guide {
    padding: clamp(64px, 8vw, 112px) 24px;
    background: #f5f5f7;
  }

  .zo-shop-guide__inner {
    width: min(100%, 1480px);
    margin: 0 auto;
  }

  .zo-section-head--center {
    margin-left: auto;
    margin-right: auto;
    text-align: center;
  }

  .zo-shop-guide__steps {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 18px;
    margin-top: 38px;
  }

  .zo-guide-step {
    min-height: 220px;
    padding: 28px;
    border: 1px solid #e8e8ed;
    border-radius: 22px;
    background: #ffffff;
  }

  .zo-guide-step span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 999px;
    background: #f5f5f7;
    color: #0F766E;
    font-weight: 800;
    margin-bottom: 34px;
  }

  .zo-guide-step h3 {
    margin: 0 0 10px;
    color: #1d1d1f;
    font-size: 22px;
    font-weight: 760;
  }

  .zo-guide-step p {
    margin: 0;
    color: #6e6e73;
    line-height: 1.6;
  }

  @media (max-width: 820px) {
    .zo-shop-guide__steps {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Shop Guide",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "How it works"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Build your glasses in three simple steps."
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "A guided order flow keeps frame, lens, and prescription details together."
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Choose a frame"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Browse by shape, material, gender, and size."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Guide",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Choose a frame",
            "text": "Browse by shape, material, gender, and size."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Pick lenses",
            "text": "Select single vision, progressive, blue cut, or photochromic upgrades."
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Add prescription",
            "text": "Enter SPH, CYL, Axis, and PD manually or upload a prescription file."
          }
        }
      ]
    }
  ]
}
{% endschema %}
