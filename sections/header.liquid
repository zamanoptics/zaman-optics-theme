         viewBox="0 0 24 24" stroke="#1A1A1A" 
         stroke-width="2.5">
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
  <a href="/" class="zaman-mobile-logo">Zaman Optics</a>
  <a href="/cart" class="zaman-mobile-cart">
    <svg width="24" height="24" fill="none" 
         viewBox="0 0 24 24" stroke="#1A1A1A" 
         stroke-width="2">
      <path d="M9 22c.55 0 1-.45 1-1s-.45-1-1-1
               -1 .45-1 1 .45 1 1 1zm11 0c.55 0 
               1-.45 1-1s-.45-1-1-1-1 .45-1 1 
               .45 1 1 1zM1 1h4l2.68 13.39a2 2 
               0 0 0 2 1.61h9.72a2 2 0 0 0 
               2-1.61L23 6H6"/>
    </svg>
    {% if cart.item_count > 0 %}
