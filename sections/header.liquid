{{ 'zaman-header.css' | asset_url | stylesheet_tag }}
{{ 'zaman-header-nav.css' | asset_url | stylesheet_tag }}

<div class="zaman-announcement">
  <div class="zaman-announcement__inner">
    <span>Free delivery over Rs 3,000</span>
    <span>Cash on Delivery</span>
    <span>WhatsApp: +92 300 8888888</span>
  </div>
</div>

<header class="zaman-header">
  <div class="zaman-header-inner">
    <button class="zaman-burger zaman-burger--desktop" type="button" onclick="openMobileMenu()" aria-label="Open menu">
      {% render 'zaman-premium-icon', icon: 'menu', size: 22 %}
    </button>

    <a href="/" class="zaman-logo" aria-label="Zaman Optics home">
      {% render 'zaman-premium-icon', icon: 'glasses', size: 32 %}
      <span class="zaman-logo-name">Zaman Optics</span>
    </a>

    <nav class="zaman-header-nav" aria-label="Main">
      <a href="/collections" class="zaman-header-navlink">Collections</a>
      <a href="/collections/all" class="zaman-header-navlink">All Products</a>
      <a href="/pages/contact" class="zaman-header-navlink">Contact</a>
    </nav>

    <form action="/search" method="get" class="zaman-search" role="search">
      <input
        type="search"
        name="q"
        placeholder="Search frames, lenses, sunglasses"
        class="zaman-search-input"
        autocomplete="off">
      <button type="submit" class="zaman-search-btn" aria-label="Search">
        {% render 'zaman-premium-icon', icon: 'search', size: 18 %}
      </button>
    </form>

    <div class="zaman-header-icons">
      <a href="/account" class="zaman-icon-btn" aria-label="Account">
        {% render 'zaman-premium-icon', icon: 'account', size: 22 %}
      </a>
      <a href="/cart" class="zaman-cart-btn" aria-label="Cart">
        {% render 'zaman-premium-icon', icon: 'cart', size: 22 %}
        {% if cart.item_count > 0 %}
          <span class="zaman-cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
    </div>
  </div>
</header>

<nav class="zaman-nav" aria-label="Collections">
  <div class="zaman-nav-inner">
    <a href="/collections/eyeglasses" class="zaman-nav-link">Eyeglasses</a>
    <a href="/collections/sunglasses" class="zaman-nav-link">Sunglasses</a>
    <a href="/collections/blue-light-glasses" class="zaman-nav-link">Blue Light Glasses</a>
    <a href="/collections/kids-glasses" class="zaman-nav-link">Kids Glasses</a>
    <a href="/collections/contact-lenses" class="zaman-nav-link">Contact Lenses</a>
    <a href="/collections/new-arrivals" class="zaman-nav-link">New Arrivals</a>
    <a href="/collections/best-sellers" class="zaman-nav-link">Best Sellers</a>
    <a href="/pages/lens-guide" class="zaman-nav-link">Lens Guide</a>
    <a href="/pages/size-guide" class="zaman-nav-link">Size Guide</a>
    <a href="/pages/prescription-guide" class="zaman-nav-link">Prescription Guide</a>
    <a href="/pages/faq" class="zaman-nav-link">FAQ</a>
  </div>
</nav>

<header class="zaman-mobile-header">
  <button class="zaman-burger" id="zamanBurger" type="button" onclick="openMobileMenu()" aria-label="Open menu">
    {% render 'zaman-premium-icon', icon: 'menu', size: 24 %}
  </button>
  <a href="/" class="zaman-mobile-logo">Zaman Optics</a>
  <a href="/cart" class="zaman-mobile-cart" aria-label="Cart">
    {% render 'zaman-premium-icon', icon: 'cart', size: 24 %}
    {% if cart.item_count > 0 %}
      <span class="zaman-cart-count">{{ cart.item_count }}</span>
    {% endif %}
  </a>
</header>

<div class="zaman-overlay" id="zamanOverlay" onclick="closeMobileMenu()"></div>

<aside class="zaman-drawer" id="zamanDrawer" aria-label="Mobile menu">
  <div class="zdrawer-head">
    <a href="/" class="zdrawer-brand">
      <span>Zaman Optics</span>
    </a>
    <button class="zdrawer-close" type="button" onclick="closeMobileMenu()" aria-label="Close menu">
      {% render 'zaman-premium-icon', icon: 'close', size: 18 %}
    </button>
  </div>

  <div class="zdrawer-search-wrap">
    <form action="/search" method="get" class="zdrawer-search-form" role="search">
      <input type="search" name="q" placeholder="Search frames" class="zdrawer-search-input">
    </form>
  </div>

  <p class="zdrawer-section-label">Shop</p>
  <a href="/collections/eyeglasses" class="zdrawer-link"><span>Prescription Glasses</span><small>Frames with lens options</small></a>
  <a href="/collections/sunglasses" class="zdrawer-link"><span>Sunglasses</span><small>UV protection styles</small></a>
  <a href="/collections/blue-light-glasses" class="zdrawer-link"><span>Screen Glasses</span><small>Blue cut comfort</small></a>
  <a href="/collections/kids-glasses" class="zdrawer-link"><span>Kids Glasses</span><small>Lightweight daily frames</small></a>
  <a href="/collections/contact-lenses" class="zdrawer-link"><span>Contact Lenses</span><small>Daily and monthly options</small></a>

  <p class="zdrawer-section-label">Help</p>
  <a href="/pages/lens-guide" class="zdrawer-link zdrawer-link-plain"><span>Lens Guide</span></a>
  <a href="/pages/size-guide" class="zdrawer-link zdrawer-link-plain"><span>Size Guide</span></a>
  <a href="/pages/prescription-guide" class="zdrawer-link zdrawer-link-plain"><span>Prescription Guide</span></a>
  <a href="/pages/contact" class="zdrawer-link zdrawer-link-plain"><span>Contact</span></a>
  <a href="/account" class="zdrawer-link zdrawer-link-plain"><span>Account</span></a>
</aside>

<script>
function openMobileMenu() {
  var drawer = document.getElementById('zamanDrawer');
  var overlay = document.getElementById('zamanOverlay');
  if (drawer) drawer.classList.add('open');
  if (overlay) overlay.classList.add('open');
  document.body.style.overflow = 'hidden';
}

function closeMobileMenu() {
  var drawer = document.getElementById('zamanDrawer');
  var overlay = document.getElementById('zamanOverlay');
  if (drawer) drawer.classList.remove('open');
  if (overlay) overlay.classList.remove('open');
  document.body.style.overflow = '';
}

document.addEventListener('DOMContentLoaded', function() {
  var links = document.querySelectorAll('.zaman-nav-link, .zaman-header-navlink');
  links.forEach(function(link) {
    if (link.pathname === window.location.pathname) {
      link.classList.add('active');
    }
  });

  document.querySelectorAll('.zdrawer-link').forEach(function(link) {
    link.addEventListener('click', closeMobileMenu);
  });
});
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
