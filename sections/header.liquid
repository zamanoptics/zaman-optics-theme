<link rel="stylesheet" href="{{ 'section-header.css' | asset_url }}" media="print" onload="this.media='all'">

<header class="farmart-header">
  <div class="page-width">
    <div class="farmart-header__top">
      <div class="header__logo">
        {% if section.settings.logo != blank %}
          <img src="{{ section.settings.logo | img_url: 'master' }}" alt="{{ shop.name }}" width="150">
        {% else %}
          <h2>{{ shop.name }}</h2>
        {% endif %}
      </div>
      
      <div class="header__search">
        <form action="/search" method="get" role="search">
          <input type="search" name="q" placeholder="Search for products...">
          <button type="submit">Search</button>
        </form>
      </div>
      
      <div class="header__icons">
        <a href="/account">{% render 'icon-account' %}</a>
        <a href="/cart">{% render 'icon-cart' %}</a>
      </div>
    </div>
  </div>

  <div class="farmart-header__bottom">
    <div class="page-width">
      <nav>
        {% for link in linklists[section.settings.menu].links %}
          <a href="{{ link.url }}">{{ link.title }}</a>
        {% endfor %}
      </nav>
    </div>
  </div>
</header>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}


