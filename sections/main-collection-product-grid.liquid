{% comment %} Zaman Optics - Collection Page {% endcomment %}

<!-- Collection Hero Banner -->
<div class="zaman-collection-hero">
  <div class="zaman-collection-hero-inner">
    <div class="zaman-collection-breadcrumb">
      <a href="/">Home</a>
      <span>›</span>
      <span>{{ collection.title }}</span>
    </div>
    <h1 class="zaman-collection-title">
      {{ collection.title }}
    </h1>
    <p class="zaman-collection-desc">
      {% if collection.description != blank %}
        {{ collection.description }}
      {% else %}
        Explore our premium collection of 
        {{ collection.title | downcase }} — 
        crafted for style and clarity.
      {% endif %}
    </p>
    <div class="zaman-collection-meta">
      <span class="zaman-product-count">
        {{ collection.products_count }} Products
      </span>
    </div>
  </div>
</div>

<!-- Main Collection Layout -->
<div class="zaman-coll-layout">

  <!-- LEFT FILTER SIDEBAR -->
  <aside class="zaman-coll-filters">
    <form id="ZamanFilterForm"
          action="{{ collection.url }}"
          method="get">
      <input type="hidden" name="sort_by"
             value="{{ collection.sort_by }}">

      <!-- Filter Header -->
      <div class="zcf-header">
        <div class="zcf-header-left">
          <svg width="16" height="16" fill="none"
               viewBox="0 0 24 24" stroke="#FF8C00"
               stroke-width="2.5">
            <polygon points="22 3 2 3 10 12.46 
                             10 19 14 21 14 12.46 22 3"/>
          </svg>
          <span>Filters</span>
        </div>
        <a href="{{ collection.url }}" 
           class="zcf-clear">Clear</a>
      </div>

      <!-- Frame Shape -->
      <details class="zcf-group" open>
        <summary class="zcf-group-title">
          Frame Shape
          <span class="zcf-arrow">▼</span>
        </summary>
        <div class="zcf-options">
          {% for shape in 'Round,Square,Rectangle,Aviator,Cat Eye' | split: ',' %}
          <label class="zcf-option">
            <input type="checkbox"
              name="filter.p.m.custom.frame_shape"
              value="{{ shape }}"
              class="zcf-checkbox"
              {% if current_tags contains shape %}checked{% endif %}
              onchange="document.getElementById('ZamanFilterForm').submit()">
            <span class="zcf-box"></span>
            <span class="zcf-label">{{ shape }}</span>
          </label>
          {% endfor %}
        </div>
      </details>

      <!-- Material -->
      <details class="zcf-group" open>
        <summary class="zcf-group-title">
          Material
          <span class="zcf-arrow">▼</span>
        </summary>
        <div class="zcf-options">
          {% for mat in 'Metal,Acetate,Plastic' | split: ',' %}
          <label class="zcf-option">
            <input type="checkbox"
              name="filter.p.m.custom.material"
              value="{{ mat }}"
              class="zcf-checkbox"
              {% if current_tags contains mat %}checked{% endif %}
              onchange="document.getElementById('ZamanFilterForm').submit()">
            <span class="zcf-box"></span>
            <span class="zcf-label">{{ mat }}</span>
          </label>
          {% endfor %}
        </div>
      </details>

      <!-- Gender -->
      <details class="zcf-group" open>
        <summary class="zcf-group-title">
          Gender
          <span class="zcf-arrow">▼</span>
        </summary>
        <div class="zcf-options">
          {% for g in 'Men,Women,Unisex,Kids' | split: ',' %}
          <label class="zcf-option">
            <input type="checkbox"
              name="filter.p.m.custom.gender"
              value="{{ g }}"
              class="zcf-checkbox"
              {% if current_tags contains g %}checked{% endif %}
              onchange="document.getElementById('ZamanFilterForm').submit()">
            <span class="zcf-box"></span>
            <span class="zcf-label">{{ g }}</span>
          </label>
          {% endfor %}
        </div>
      </details>

      <!-- Size -->
      <details class="zcf-group">
        <summary class="zcf-group-title">
          Size
          <span class="zcf-arrow">▼</span>
        </summary>
        <div class="zcf-options">
          {% for sz in 'Medium,Wide' | split: ',' %}
          <label class="zcf-option">
            <input type="checkbox"
              name="filter.p.m.custom.size"
              value="{{ sz }}"
              class="zcf-checkbox"
              {% if current_tags contains sz %}checked{% endif %}
              onchange="document.getElementById('ZamanFilterForm').submit()">
            <span class="zcf-box"></span>
            <span class="zcf-label">{{ sz }}</span>
          </label>
          {% endfor %}
        </div>
      </details>

      <!-- Price -->
      <details class="zcf-group">
        <summary class="zcf-group-title">
          Price Range
          <span class="zcf-arrow">▼</span>
        </summary>
        <div class="zcf-options">
          <div class="zcf-price-row">
            <input type="number"
              name="filter.v.price.gte"
              placeholder="Min Rs"
              class="zcf-price-in">
            <span>—</span>
            <input type="number"
              name="filter.v.price.lte"
              placeholder="Max Rs"
              class="zcf-price-in">
          </div>
          <button type="submit" class="zcf-price-btn">
            Apply
          </button>
        </div>
      </details>

    </form>
  </aside>

  <!-- RIGHT PRODUCTS AREA -->
  <div class="zaman-coll-right">

    <!-- Sort Bar -->
    <div class="zaman-sort-bar">
      <span class="zaman-sort-count">
        <strong>{{ collection.products_count }}</strong>
        products
      </span>
      <div class="zaman-sort-right">
        <label>Sort:</label>
        <select class="zaman-sort-sel"
          onchange="window.location.href=
            '{{ collection.url }}?sort_by='+this.value">
          <option value="best-selling"
            {% if collection.sort_by=='best-selling' %}selected{% endif %}>
            Best Selling</option>
          <option value="price-ascending"
            {% if collection.sort_by=='price-ascending' %}selected{% endif %}>
            Price: Low–High</option>
          <option value="price-descending"
            {% if collection.sort_by=='price-descending' %}selected{% endif %}>
            Price: High–Low</option>
          <option value="created-descending"
            {% if collection.sort_by=='created-descending' %}selected{% endif %}>
            Newest</option>
          <option value="title-ascending"
            {% if collection.sort_by=='title-ascending' %}selected{% endif %}>
            Name A–Z</option>
        </select>
      </div>
    </div>

    <!-- Product Grid -->
    {% if collection.products.size > 0 %}
    <div class="zaman-prod-grid">
      {% for product in collection.products %}
      <a href="{{ product.url }}"
         class="zaman-card">

        <!-- Badge -->
        <div class="zaman-card-badge
          {% if product.available == false %}
            zcb-sold
          {% elsif product.compare_at_price > product.price %}
            zcb-sale
          {% else %}
            zcb-new
          {% endif %}">
          {% if product.available == false %}
            Sold Out
          {% elsif product.compare_at_price > product.price %}
            Sale
          {% else %}
            New
          {% endif %}
        </div>

        <!-- Image area with hover swap -->
        <div class="zaman-card-img-wrap">
          {% if product.images.size > 0 %}
          <img
            src="{{ product.images[0] | img_url: '600x500', crop: 'center' }}"
            alt="{{ product.title }}"
            class="zaman-card-img zaman-img-primary"
            loading="lazy">
          {% if product.images.size > 1 %}
          <img
            src="{{ product.images[1] | img_url: '600x500', crop: 'center' }}"
            alt="{{ product.title }} alternate"
            class="zaman-card-img zaman-img-secondary"
            loading="lazy">
          {% endif %}
          {% else %}
          <div class="zaman-card-no-img">
            <svg width="40" height="40" fill="none"
                 viewBox="0 0 24 24" stroke="#CCCCCC"
                 stroke-width="1.5">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span>No image</span>
          </div>
          {% endif %}
        </div>

        <!-- Card Info -->
        <div class="zaman-card-info">
          <span class="zaman-card-cat">
            {{ collection.title }}
          </span>
          <h3 class="zaman-card-name">
            {{ product.title }}
          </h3>
          <div class="zaman-card-price-row">
            <span class="zaman-card-price">
              {{ product.price | money }}
            </span>
            {% if product.compare_at_price > product.price %}
            <span class="zaman-card-was">
              {{ product.compare_at_price | money }}
            </span>
            {% endif %}
          </div>
          <div class="zaman-card-footer">
            <span class="zaman-card-cta">
              View Details →
            </span>
            {% if product.images.size > 1 %}
            <span class="zaman-card-imgs-hint">
              +{{ product.images.size }} photos
            </span>
            {% endif %}
          </div>
        </div>

      </a>
      {% endfor %}
    </div>

    {% else %}
    <div class="zaman-empty">
      <p>No products found.</p>
      <a href="{{ collection.url }}">Clear filters</a>
    </div>
    {% endif %}

  </div>
</div>
