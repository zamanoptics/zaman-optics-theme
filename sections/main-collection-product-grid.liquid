{%- liquid
  assign sort_by = collection.sort_by | default: collection.default_sort_by
  assign has_shopify_filters = false
  if collection.filters.size > 0
    assign has_shopify_filters = true
  endif
  assign has_active_filters = false
-%}

{%- paginate collection.products by 12 -%}

<div class="zcoll-hero">
  <div class="zcoll-hero-inner">
    <nav class="zcoll-breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span>/</span>
      <span>{{ collection.title }}</span>
    </nav>
    <h1 class="zcoll-hero-title">{{ collection.title }}</h1>
    {% if collection.description != blank %}
      <p class="zcoll-hero-desc">{{ collection.description }}</p>
    {% endif %}
    <span class="zcoll-hero-count">{{ collection.products_count }} Products</span>
  </div>
</div>

<div class="zcoll-mobile-bar">
  <button class="zcoll-filter-toggle" type="button" onclick="zamanOpenFilter()">
    {% render 'zaman-premium-icon', icon: 'filter', size: 16 %}
    Filters
  </button>
  <select class="zcoll-mobile-sort" aria-label="Sort products" onchange="zamanApplySort(this.value)">
    <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
    <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
    <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
    <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Newest</option>
    <option value="title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>Name: A-Z</option>
  </select>
</div>

<div class="zcoll-body">
  <div class="zcoll-filter-overlay" id="zamanFilterOverlay" onclick="zamanCloseFilter()"></div>

  <aside class="zcoll-sidebar" id="zamanSidebar" aria-label="Collection filters">
    <button class="zcoll-sidebar-close" type="button" onclick="zamanCloseFilter()">Close filters</button>

    <form id="ZCF" action="{{ collection.url }}" method="get" class="zcf-form">
      <input type="hidden" name="sort_by" value="{{ sort_by }}">

      <div class="zcf-head">
        <span>Filters</span>
        <a href="{{ collection.url }}" class="zcf-reset">Reset</a>
      </div>

      {% if has_shopify_filters %}
        {% for filter in collection.filters %}
          {% if filter.type == 'list' and filter.active_values.size > 0 %}
            {% assign has_active_filters = true %}
          {% elsif filter.type == 'price_range' %}
            {% if filter.min_value.value != nil or filter.max_value.value != nil %}
              {% assign has_active_filters = true %}
            {% endif %}
          {% endif %}

          <details class="zcf-group" open>
            <summary class="zcf-title">
              <span>{{ filter.label }}</span>
              <span class="zcf-chevron">{% render 'zaman-premium-icon', icon: 'chevron-down', size: 14 %}</span>
            </summary>

            {% case filter.type %}
              {% when 'list' %}
                <ul class="zcf-list">
                  {% for value in filter.values %}
                    <li class="zcf-item">
                      <label class="zcf-label{% if value.count == 0 and value.active == false %} zcf-label--disabled{% endif %}">
                        <input
                          type="checkbox"
                          class="zcf-cb"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}checked{% endif %}
                          {% if value.count == 0 and value.active == false %}disabled{% endif %}
                          onchange="this.form.submit()">
                        <span class="zcf-custom-cb"></span>
                        <span class="zcf-text">{{ value.label }}</span>
                        <span class="zcf-count">{{ value.count }}</span>
                      </label>
                    </li>
                  {% endfor %}
                </ul>

              {% when 'price_range' %}
                <div class="zcf-price-block">
                  <div class="zcf-price-inputs">
                    <div class="zcf-price-field">
                      <label for="Filter-{{ filter.min_value.param_name | escape }}">Min (Rs)</label>
                      <input
                        id="Filter-{{ filter.min_value.param_name | escape }}"
                        type="number"
                        name="{{ filter.min_value.param_name }}"
                        min="0"
                        {% if filter.range_max != blank %}
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                        {% endif %}
                        {% if filter.min_value.value != nil %}
                          value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"
                        {% endif %}
                        placeholder="0"
                        class="zcf-price-input">
                    </div>
                    <span class="zcf-price-dash">-</span>
                    <div class="zcf-price-field">
                      <label for="Filter-{{ filter.max_value.param_name | escape }}">Max (Rs)</label>
                      <input
                        id="Filter-{{ filter.max_value.param_name | escape }}"
                        type="number"
                        name="{{ filter.max_value.param_name }}"
                        min="0"
                        {% if filter.range_max != blank %}
                          max="{{ filter.range_max | money_without_currency | replace: ',', '' }}"
                        {% endif %}
                        {% if filter.max_value.value != nil %}
                          value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"
                        {% endif %}
                        placeholder="15000"
                        class="zcf-price-input">
                    </div>
                  </div>
                  <button type="submit" class="zcf-apply-btn">Apply Price</button>
                </div>
            {% endcase %}
          </details>
        {% endfor %}
      {% else %}
        {% render 'collection-fallback-filters', current_tags: current_tags %}
      {% endif %}
    </form>
  </aside>

  <div class="zcoll-right">
    <div class="zcoll-grid-header">
      <div class="zcoll-grid-label">
        <span class="zcoll-grid-badge">Shop Frames</span>
        <h2 class="zcoll-grid-title">{{ collection.title }}</h2>
      </div>
      <div class="zcoll-grid-stats">
        <span class="zcoll-grid-count">{{ collection.products_count }} Products</span>
      </div>
    </div>

    {% if has_active_filters or current_tags.size > 0 %}
      <div class="zcoll-active-filters" aria-label="Active filters">
        {% if has_shopify_filters %}
          {% for filter in collection.filters %}
            {% for value in filter.active_values %}
              <a class="zcoll-filter-chip" href="{{ value.url_to_remove }}">{{ value.label }} <span>x</span></a>
            {% endfor %}
            {% if filter.type == 'price_range' %}
              {% if filter.min_value.value != nil or filter.max_value.value != nil %}
                <a class="zcoll-filter-chip" href="{{ filter.url_to_remove }}">
                  Price
                  <span>x</span>
                </a>
              {% endif %}
            {% endif %}
          {% endfor %}
        {% else %}
          {% for tag in current_tags %}
            <span class="zcoll-filter-chip">{{ tag }}</span>
          {% endfor %}
        {% endif %}
        <a class="zcoll-clear-filters" href="{{ collection.url }}">Clear all</a>
      </div>
    {% endif %}

    <div class="zcoll-sort-bar">
      <p class="zcoll-count">
        Showing <strong>{{ collection.products_count }}</strong> {{ collection.title }} products
      </p>
      <div class="zcoll-sort-wrap">
        <label class="zcoll-sort-label" for="SortByDesktop">Sort by:</label>
        <select id="SortByDesktop" class="zcoll-sort-select" onchange="zamanApplySort(this.value)">
          <option value="best-selling" {% if sort_by == 'best-selling' %}selected{% endif %}>Best Selling</option>
          <option value="price-ascending" {% if sort_by == 'price-ascending' %}selected{% endif %}>Price: Low to High</option>
          <option value="price-descending" {% if sort_by == 'price-descending' %}selected{% endif %}>Price: High to Low</option>
          <option value="created-descending" {% if sort_by == 'created-descending' %}selected{% endif %}>Newest First</option>
          <option value="title-ascending" {% if sort_by == 'title-ascending' %}selected{% endif %}>Name: A-Z</option>
        </select>
      </div>
    </div>

    {% if collection.products.size > 0 %}
      <div class="zcoll-grid">
        {% for product in collection.products %}
          {%- assign first_img = product.images[0] -%}
          {%- assign second_img = product.images[1] -%}

          <a href="{{ product.url }}" class="zcard" aria-label="{{ product.title }}">
            <div class="zcard-badge {% if product.available == false %}zcard-badge--sold{% elsif product.compare_at_price > product.price %}zcard-badge--sale{% else %}zcard-badge--new{% endif %}">
              {% if product.available == false %}
                Sold Out
              {% elsif product.compare_at_price > product.price %}
                Sale
              {% else %}
                New
              {% endif %}
            </div>

            <div class="zcard-images">
              {% if first_img %}
                <img
                  src="{{ first_img | image_url: width: 640 }}"
                  alt="{{ product.title }}"
                  class="zcard-img zcard-img--primary"
                  width="640"
                  height="480"
                  loading="lazy">
              {% endif %}
              {% if second_img %}
                <img
                  src="{{ second_img | image_url: width: 640 }}"
                  alt="{{ product.title }} alternate view"
                  class="zcard-img zcard-img--secondary"
                  width="640"
                  height="480"
                  loading="lazy">
              {% endif %}
              {% unless first_img %}
                <div class="zcard-no-img">
                  {% render 'zaman-premium-icon', icon: 'image', size: 48 %}
                  <span>No image</span>
                </div>
              {% endunless %}
            </div>

            <div class="zcard-info">
              <span class="zcard-collection-tag">{{ collection.title }}</span>
              <h3 class="zcard-title">{{ product.title }}</h3>
              <div class="zcard-pricing">
                <span class="zcard-price">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="zcard-compare-price">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>
              <div class="zcard-bottom">
                <span class="zcard-cta-text">
                  View Details
                  {% render 'zaman-premium-icon', icon: 'arrow-right', size: 12 %}
                </span>
                {% if product.images.size > 1 %}
                  <span class="zcard-photo-count">{{ product.images.size }} photos</span>
                {% endif %}
              </div>
            </div>
          </a>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <div class="zcoll-pagination">
          {% if paginate.previous %}
            <a href="{{ paginate.previous.url }}" class="zcoll-page-btn">Previous</a>
          {% endif %}
          {% for part in paginate.parts %}
            {% if part.is_link %}
              <a href="{{ part.url }}" class="zcoll-page-btn">{{ part.title }}</a>
            {% else %}
              <span class="zcoll-page-btn zcoll-page-current">{{ part.title }}</span>
            {% endif %}
          {% endfor %}
          {% if paginate.next %}
            <a href="{{ paginate.next.url }}" class="zcoll-page-btn">Next</a>
          {% endif %}
        </div>
      {% endif %}
    {% else %}
      <div class="zcoll-empty">
        {% render 'zaman-premium-icon', icon: 'search', size: 64 %}
        <h3>No products found</h3>
        <p>Try adjusting your filters</p>
        <a href="{{ collection.url }}" class="zcoll-empty-reset">Clear All Filters</a>
      </div>
    {% endif %}
  </div>
</div>

<script>
function zamanOpenFilter() {
  document.getElementById('zamanSidebar').classList.add('zcoll-sidebar--open');
  document.getElementById('zamanFilterOverlay').classList.add('zcoll-overlay--open');
  document.body.style.overflow = 'hidden';
}

function zamanCloseFilter() {
  document.getElementById('zamanSidebar').classList.remove('zcoll-sidebar--open');
  document.getElementById('zamanFilterOverlay').classList.remove('zcoll-overlay--open');
  document.body.style.overflow = '';
}

function zamanApplySort(value) {
  const url = new URL(window.location.href);
  url.searchParams.set('sort_by', value);
  window.location.href = url.toString();
}

function updateTagFilters() {
  const checkedTags = Array.from(document.querySelectorAll('.zcf-tag-filter:checked'))
    .map((cb) => cb.dataset.tag.trim().toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, ''));

  let url = '{{ collection.url }}';
  if (checkedTags.length > 0) {
    url = url.replace(/\/$/, '') + '/' + checkedTags.map(encodeURIComponent).join('+');
  }

  const currentUrl = new URL(window.location.href);
  const sortBy = currentUrl.searchParams.get('sort_by') || '{{ sort_by }}';
  if (sortBy) {
    url += '?sort_by=' + encodeURIComponent(sortBy);
  }

  window.location.href = url;
}
</script>

{%- endpaginate -%}

{% schema %}
{
  "name": "Collection Grid",
  "settings": []
}
{% endschema %}
