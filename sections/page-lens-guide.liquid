{% comment %}
  Lens Guide Section
  Displays information about different lens types with card layout
{% endcomment %}

{{ 'page-lens-guide.css' | asset_url | stylesheet_tag }}

<div class="lens-guide">
  <div class="lens-guide__container">
    <header class="lens-guide__header">
      <h1 class="lens-guide__title">{{ page.title }}</h1>
      {% if page.content %}
        <div class="lens-guide__intro">
          {{ page.content }}
        </div>
      {% endif %}
    </header>

    <div class="lens-guide__cards">
      <div class="lens-guide__card">
        <div class="lens-guide__card-header">
          <h2 class="lens-guide__card-title">Single Vision</h2>
        </div>

        <div class="lens-guide__card-content">
          <p class="lens-guide__description">
            Single vision lenses use one optical power across the lens. They are made for one main viewing distance, such as reading, computer work, or distance vision.
          </p>

          <div class="lens-guide__section">
            <h3 class="lens-guide__section-title">Who It's For</h3>
            <ul class="lens-guide__list">
              <li>People who need correction for one distance</li>
              <li>First-time eyeglass wearers</li>
              <li>Customers who do not need multifocal lenses</li>
              <li>Daily wear for work, study, or distance vision</li>
            </ul>
          </div>

          <div class="lens-guide__section">
            <h3 class="lens-guide__section-title">Price Range</h3>
            <p class="lens-guide__price-note">
              Included with most prescription orders; upgrades depend on lens material and coatings.
            </p>
          </div>
        </div>
      </div>

      <div class="lens-guide__card">
        <div class="lens-guide__card-header">
          <h2 class="lens-guide__card-title">Progressive</h2>
        </div>

        <div class="lens-guide__card-content">
          <p class="lens-guide__description">
            Progressive lenses support near, intermediate, and distance vision in one lens without a visible line.
          </p>

          <div class="lens-guide__section">
            <h3 class="lens-guide__section-title">Who It's For</h3>
            <ul class="lens-guide__list">
              <li>Customers who need help seeing at multiple distances</li>
              <li>People who use reading and distance correction</li>
              <li>Office and screen users who move between tasks</li>
              <li>Anyone who wants one pair for daily use</li>
            </ul>
          </div>

          <div class="lens-guide__section">
            <h3 class="lens-guide__section-title">Price Range</h3>
            <p class="lens-guide__price-note">
              Progressive upgrade starts from <strong>Rs 1,200</strong>.
            </p>
          </div>
        </div>
      </div>

      <div class="lens-guide__card">
        <div class="lens-guide__card-header">
          <h2 class="lens-guide__card-title">Blue Cut</h2>
        </div>

        <div class="lens-guide__card-content">
          <p class="lens-guide__description">
            Blue cut lenses are designed for customers who spend long hours around phones, laptops, and other screens.
          </p>

          <div class="lens-guide__section">
            <h3 class="lens-guide__section-title">Who It's For</h3>
            <ul class="lens-guide__list">
              <li>Students and office workers</li>
              <li>Customers who spend long hours on screens</li>
              <li>Remote workers and digital professionals</li>
              <li>Anyone looking for everyday screen comfort</li>
            </ul>
          </div>

          <div class="lens-guide__section">
            <h3 class="lens-guide__section-title">Price Range</h3>
            <p class="lens-guide__price-note">
              Blue Cut upgrade starts from <strong>Rs 500</strong>.
            </p>
          </div>
        </div>
      </div>
    </div>

    <div class="lens-guide__cta">
      <p>Ready to choose a frame and compare lens options?</p>
      <a href="/collections/all" class="lens-guide__button">Browse Eyewear</a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Lens Guide",
  "settings": [
    {
      "type": "text",
      "id": "page_title",
      "label": "Page Title",
      "default": "Lens Guide"
    }
  ]
}
{% endschema %}
