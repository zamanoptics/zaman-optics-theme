{{ 'footer-custom.css' | asset_url | stylesheet_tag }}

<footer class="footer-custom">
  <div class="footer-custom__content">
    <section class="footer-custom__brand-panel" aria-label="Zaman Optics store information">
      <div>
        <a href="{{ routes.root_url }}" class="footer-custom__brand-name">Zaman Optics</a>
        <p class="footer-custom__tagline">
          Thoughtfully selected eyewear, prescription lens support, and local optical care from Gujar Khan.
        </p>
      </div>

      <div class="footer-custom__payment-methods" aria-label="Payment methods">
        <span class="footer-custom__payment-badge">Online Payments</span>
        <span class="footer-custom__payment-badge">Secure Checkout</span>
        <span class="footer-custom__payment-badge">PKR Pricing</span>
        <span class="footer-custom__payment-badge">Pakistan Delivery</span>
      </div>
    </section>

    <div class="footer-custom__container">
      <nav class="footer-custom__column" aria-label="Shop collections">
        <h2 class="footer-custom__column-title">Shop</h2>
        <ul class="footer-custom__link-list">
          <li><a href="/collections/eyeglasses">Eyeglasses</a></li>
          <li><a href="/collections/sunglasses">Sunglasses</a></li>
          <li><a href="/collections/blue-light-glasses">Blue Light Glasses</a></li>
          <li><a href="/collections/kids-glasses">Kids Glasses</a></li>
          <li><a href="/collections/contact-lenses">Contact Lenses</a></li>
        </ul>
      </nav>

      <nav class="footer-custom__column" aria-label="Discover products">
        <h2 class="footer-custom__column-title">Discover</h2>
        <ul class="footer-custom__link-list">
          <li><a href="/collections/all">All Products</a></li>
          <li><a href="/collections/new-arrivals">New Arrivals</a></li>
          <li><a href="/collections/best-sellers">Best Sellers</a></li>
          <li><a href="/pages/lens-guide">Lens Guide</a></li>
          <li><a href="/pages/size-guide">Size Guide</a></li>
        </ul>
      </nav>

      <nav class="footer-custom__column" aria-label="Customer help">
        <h2 class="footer-custom__column-title">Help</h2>
        <ul class="footer-custom__link-list">
          <li><a href="/pages/prescription-guide">Prescription Guide</a></li>
          <li><a href="/pages/faq">FAQ</a></li>
          <li><a href="/pages/about">About</a></li>
          <li><a href="/pages/contact">Contact</a></li>
          <li><a href="/policies/refund-policy">Return Policy</a></li>
        </ul>
      </nav>

      <section class="footer-custom__column" aria-label="Contact details">
        <h2 class="footer-custom__column-title">Support</h2>
        <p class="footer-custom__contact-item">
          Gujar Khan, Punjab, Pakistan
        </p>
        <p class="footer-custom__contact-item">
          WhatsApp support<br>
          <a href="https://wa.me/923008888888">+92 300 8888888</a>
        </p>
        <p class="footer-custom__contact-item">
          Hours<br>
          Mon-Sat, 10:00 AM-8:00 PM
        </p>
      </section>
    </div>

    <div class="footer-custom__bottom">
      <p>Copyright {{ 'now' | date: '%Y' }} Zaman Optics. All rights reserved.</p>
      <div class="footer-custom__bottom-links">
        <a href="/policies/privacy-policy">Privacy</a>
        <a href="/policies/terms-of-service">Terms</a>
        <a href="/pages/contact">Support</a>
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": []
}
{% endschema %}
