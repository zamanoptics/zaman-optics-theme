{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

{%- style -%}
  /* Premium Homepage Hero Section */
  
  .hero-section {
    background-color: #FFFFFF;
    min-height: 500px;
    display: flex;
    align-items: stretch;
  }

  .hero-section__content {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 4rem 3rem;
    max-width: 50%;
  }

  .hero-section__text-wrapper {
    width: 100%;
  }

  .hero-section__label {
    color: #6BA3BE;
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    margin: 0 0 1.5rem 0;
    display: block;
  }

  .hero-section__heading {
    color: #1A1A1A;
    font-size: 3.25rem;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -0.02em;
    margin: 0 0 1.5rem 0;
  }

  .hero-section__subheading {
    color: #666666;
    font-size: 1.125rem;
    line-height: 1.6;
    margin: 0 0 2.5rem 0;
    font-weight: 400;
  }

  .hero-section__buttons {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .hero-section__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 2rem;
    border-radius: 10px;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: all 0.3s ease;
    white-space: nowrap;
    border: none;
    cursor: pointer;
  }

  .hero-section__button--primary {
    background-color: #6BA3BE;
    color: #FFFFFF;
    box-shadow: 0 4px 12px rgba(107, 163, 190, 0.15);
  }

  .hero-section__button--primary:hover {
    background-color: #4A7A94;
    box-shadow: 0 8px 20px rgba(107, 163, 190, 0.25);
    transform: translateY(-2px);
  }

  .hero-section__button--secondary {
    background-color: transparent;
    color: #6BA3BE;
    border: 1px solid #6BA3BE;
  }

  .hero-section__button--secondary:hover {
    background-color: #E8F4F8;
    border-color: #4A7A94;
    color: #4A7A94;
  }

  .hero-section__badges {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    border-top: 1px solid #E8E8E8;
    padding-top: 2rem;
  }

  .hero-section__badge {
    color: #666666;
    font-size: 0.75rem;
    line-height: 1.5;
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
  }

  .hero-section__badge::before {
    content: "✓";
    color: #6BA3BE;
    font-weight: 700;
    flex-shrink: 0;
  }

  .hero-section__image {
    flex: 1;
    background-color: #E8F4F8;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #6BA3BE;
    font-size: 0.9375rem;
    text-align: center;
    padding: 2rem;
    line-height: 1.6;
    overflow: hidden;
  }

  .hero-section__image img,
  .hero-section__image .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Mobile Responsive */
  @media screen and (max-width: 749px) {
    .hero-section {
      min-height: 350px;
      flex-direction: column;
    }

    .hero-section__content {
      max-width: 100%;
      padding: 2.5rem 1.5rem;
      order: 2;
    }

    .hero-section__image {
      order: 1;
      min-height: 250px;
    }

    .hero-section__heading {
      font-size: 2rem;
    }

    .hero-section__subheading {
      font-size: 1rem;
      margin-bottom: 1.5rem;
    }

    .hero-section__buttons {
      flex-direction: column;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .hero-section__button {
      width: 100%;
      justify-content: center;
    }

    .hero-section__badges {
      border-top: 1px solid #E8E8E8;
      padding-top: 1.5rem;
    }

    .hero-section__badge {
      font-size: 0.7rem;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .hero-section__content {
      padding: 3rem 2rem;
    }

    .hero-section__heading {
      font-size: 2.5rem;
    }

    .hero-section__subheading {
      font-size: 1rem;
    }
  }
{%- endstyle -%}

{%- if section.settings.image_height == 'adapt' and section.settings.image != blank -%}
  {%- style -%}
    @media screen and (max-width: 749px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before,
      #Banner-{{ section.id }}:not(.banner--mobile-bottom) .banner__content::before {
        padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }

    @media screen and (min-width: 750px) {
      #Banner-{{ section.id }}::before,
      #Banner-{{ section.id }} .banner__media::before {
        padding-bottom: {{ 1 | divided_by: section.settings.image.aspect_ratio | times: 100 }}%;
        content: '';
        display: block;
      }
    }
  {%- endstyle -%}
{%- endif -%}

{%- style -%}
  #Banner-{{ section.id }}::after {
    opacity: {{ section.settings.image_overlay_opacity | divided_by: 100.0 }};
  }
{%- endstyle -%}

{%- liquid
  assign full_width = '100vw'
  assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'

  if section.settings.image_behavior == 'ambient'
    assign half_width = '60vw'
    assign full_width = '120vw'
    assign stacked_sizes = '(min-width: 750px) 60vw, 120vw'
    assign widths = '450, 660, 900, 1320, 1800, 2136, 2400, 3600, 7680'
  elsif section.settings.image_behavior == 'fixed' or section.settings.image_behavior == 'zoom-in'
    assign half_width = '100vw'
    assign stacked_sizes = '100vw'
  else
    assign half_width = '50vw'
    assign stacked_sizes = '(min-width: 750px) 50vw, 100vw'
  endif
  assign fetch_priority = 'auto'
  if section.index == 1
    assign fetch_priority = 'high'
  endif
-%}

<!-- Premium Homepage Hero Section -->
<div id="Banner-{{ section.id }}" class="hero-section{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
  <!-- Left Content Area -->
  <div class="hero-section__content">
    <div class="hero-section__text-wrapper">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <span class="hero-section__label" {{ block.shopify_attributes }}>Premium Vision Care</span>
            <h1 class="hero-section__heading" {{ block.shopify_attributes }}>
              {{ block.settings.heading | default: "Discover Your Perfect Frame" }}
            </h1>
          {%- when 'text' -%}
            <p class="hero-section__subheading" {{ block.shopify_attributes }}>
              {{ block.settings.text | default: "Experience premium eyewear crafted for style and comfort" }}
            </p>
          {%- when 'buttons' -%}
            <div class="hero-section__buttons" {{ block.shopify_attributes }}>
              {%- if block.settings.button_label_1 != blank -%}
                <a
                  {% if block.settings.button_link_1 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_1 }}"
                  {% endif %}
                  class="hero-section__button hero-section__button--primary"
                >
                  {{- block.settings.button_label_1 | escape -}}
                </a>
              {%- else -%}
                <a href="/collections/all" class="hero-section__button hero-section__button--primary">Shop Now</a>
              {%- endif -%}
              {%- if block.settings.button_label_2 != blank -%}
                <a
                  {% if block.settings.button_link_2 == blank %}
                    role="link" aria-disabled="true"
                  {% else %}
                    href="{{ block.settings.button_link_2 }}"
                  {% endif %}
                  class="hero-section__button hero-section__button--secondary"
                >
                  {{- block.settings.button_label_2 | escape -}}
                </a>
              {%- else -%}
                <a href="/pages/about" class="hero-section__button hero-section__button--secondary">Learn More</a>
              {%- endif -%}
            </div>
            <!-- Trust Badges -->
            <div class="hero-section__badges">
              <div class="hero-section__badge">Free shipping on orders above Rs 3,000</div>
              <div class="hero-section__badge">100% Original Products Guaranteed</div>
              <div class="hero-section__badge">Expert Customer Support Available</div>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>

  <!-- Right Image Area -->
  <div class="hero-section__image">
    {%- if section.settings.image != blank -%}
      {%- liquid
        assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
      -%}
      {{
        section.settings.image
        | image_url: width: 3840
        | image_tag:
          width: section.settings.image.width,
          height: image_height,
          class: 'hero-image',
          sizes: '(min-width: 750px) 50vw, 100vw',
          widths: widths,
          fetchpriority: fetch_priority
      }}
    {%- else -%}
      <div style="text-align: center; padding: 2rem;">
        <p style="color: #6BA3BE; font-size: 0.9375rem; line-height: 1.6;">Featured Product<br>Image Placeholder</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
