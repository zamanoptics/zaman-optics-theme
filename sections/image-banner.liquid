<section class="hero-wrapper" aria-label="Zaman Optics hero">
  <div class="hero-left">
    <span class="hero-label">{{ section.settings.hero_label }}</span>
    <h1 class="hero-headline">{{ section.settings.hero_headline }}</h1>
    <p class="hero-subtext">{{ section.settings.hero_subtext }}</p>

    <div class="hero-buttons">
      <a href="{{ section.settings.btn_primary_url }}" class="btn-primary">
        {{ section.settings.btn_primary_text }}
      </a>
      <a href="{{ section.settings.btn_secondary_url }}" class="btn-secondary">
        {{ section.settings.btn_secondary_text }}
      </a>
    </div>

    <div class="hero-trust">
      <div class="hero-trust-item">
        <span class="hero-trust-dot"></span>
        {{ section.settings.trust_1 }}
      </div>
      <div class="hero-trust-item">
        <span class="hero-trust-dot"></span>
        {{ section.settings.trust_2 }}
      </div>
      <div class="hero-trust-item">
        <span class="hero-trust-dot"></span>
        {{ section.settings.trust_3 }}
      </div>
    </div>
  </div>

  <div class="hero-right">
    {% if section.settings.hero_image %}
      <img
        src="{{ section.settings.hero_image | image_url: width: 1400 }}"
        alt="Premium eyeglasses and sunglasses at Zaman Optics"
        class="hero-image"
        width="1400"
        height="900"
        loading="eager">
    {% else %}
      <img
        src="{{ 'zaman-hero-eyewear.png' | asset_url }}"
        alt="Premium eyeglasses and sunglasses at Zaman Optics"
        class="hero-image"
        width="1400"
        height="900"
        loading="eager">
    {% endif %}
  </div>
</section>

<style>
.hero-wrapper {
  display: grid;
  grid-template-columns: minmax(0, 0.95fr) minmax(360px, 1.05fr);
  align-items: stretch;
  gap: clamp(22px, 4vw, 54px);
  width: min(1240px, calc(100% - 40px));
  margin: clamp(18px, 3vw, 34px) auto clamp(28px, 5vw, 54px);
  min-height: 560px;
  padding: clamp(24px, 4vw, 44px);
  background: #f5f5f7;
  border-radius: 24px;
  overflow: hidden;
  position: relative;
  box-shadow: none;
  border: 1px solid #e8e8ed;
}

.hero-wrapper::after {
  content: none;
}

.hero-left {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  max-width: 590px;
}

.hero-label {
  display: inline-flex;
  width: fit-content;
  align-items: center;
  padding: 7px 13px;
  margin-bottom: 20px;
  border: 1px solid #e8e8ed;
  border-radius: 999px;
  background: #ffffff;
  color: #6e6e73;
  font-size: 11px;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.2;
  text-transform: uppercase;
}

.hero-headline {
  margin: 0 0 18px;
  color: #1d1d1f;
  font-size: clamp(36px, 5vw, 64px);
  font-weight: 900;
  line-height: 1.02;
  letter-spacing: 0;
}

.hero-subtext {
  max-width: 500px;
  margin: 0 0 32px;
  color: #6e6e73;
  font-size: 17px;
  line-height: 1.7;
}

.hero-buttons {
  display: flex;
  flex-wrap: wrap;
  gap: 12px;
  margin-bottom: 30px;
}

.hero-buttons a {
  min-height: 48px;
  padding: 14px 26px;
  border-radius: 10px;
  font-size: 14px;
  font-weight: 850;
  line-height: 1.2;
  text-decoration: none;
  transition: transform 160ms ease, background-color 160ms ease, border-color 160ms ease, color 160ms ease, box-shadow 160ms ease;
}

.hero-buttons .btn-primary {
  background: #0F766E;
  border: 1.5px solid #0F766E;
  color: #ffffff !important;
  box-shadow: none;
}

.hero-buttons .btn-primary:hover {
  background: #0B5F59;
  border-color: #0B5F59;
  color: #ffffff !important;
  transform: translateY(-2px);
}

.hero-buttons .btn-secondary {
  background: #ffffff;
  border: 1.5px solid #d2d2d7;
  color: #1d1d1f !important;
}

.hero-buttons .btn-secondary:hover {
  background: #f5f5f7;
  border-color: #b6b6bd;
  color: #1d1d1f !important;
  transform: translateY(-2px);
}

.hero-trust {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.hero-trust-item {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 34px;
  padding: 8px 12px;
  border: 1px solid #e8e8ed;
  border-radius: 999px;
  background: #ffffff;
  color: #6e6e73;
  font-size: 12px;
  font-weight: 700;
}

.hero-trust-dot {
  width: 7px;
  height: 7px;
  border-radius: 50%;
  background: #0F766E;
  box-shadow: none;
  flex: 0 0 auto;
}

.hero-right {
  position: relative;
  z-index: 1;
  min-height: 460px;
  border-radius: 20px;
  overflow: hidden;
  background: #ffffff;
  box-shadow: none;
  border: 1px solid #e8e8ed;
}

.hero-image {
  display: block;
  width: 100%;
  height: 100%;
  min-height: 460px;
  object-fit: cover;
}

@media (max-width: 900px) {
  .hero-wrapper {
    grid-template-columns: 1fr;
    width: min(100% - 28px, 720px);
    min-height: auto;
  }

  .hero-right {
    min-height: 300px;
    order: -1;
  }

  .hero-image {
    min-height: 300px;
  }
}

@media (max-width: 520px) {
  .hero-wrapper {
    width: calc(100% - 24px);
    padding: 18px;
    border-radius: 18px;
  }

  .hero-buttons a {
    width: 100%;
    text-align: center;
  }

  .hero-trust {
    gap: 8px;
  }
}
</style>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    {
      "type": "text",
      "id": "hero_label",
      "label": "Small label above headline",
      "default": "PAKISTAN'S TRUSTED OPTICAL STORE"
    },
    {
      "type": "textarea",
      "id": "hero_headline",
      "label": "Main Headline",
      "default": "Premium Eyewear, Prescription Ready"
    },
    {
      "type": "textarea",
      "id": "hero_subtext",
      "label": "Subheadline",
      "default": "Shop frames, sunglasses, blue light protection, and custom lenses with clear pricing and delivery across Pakistan."
    },
    {
      "type": "text",
      "id": "btn_primary_text",
      "label": "Primary Button Text",
      "default": "Shop Eyeglasses"
    },
    {
      "type": "url",
      "id": "btn_primary_url",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "btn_secondary_text",
      "label": "Secondary Button Text",
      "default": "Explore Sunglasses"
    },
    {
      "type": "url",
      "id": "btn_secondary_url",
      "label": "Secondary Button Link"
    },
    {
      "type": "text",
      "id": "trust_1",
      "label": "Trust Badge 1",
      "default": "Free Delivery above Rs 3,000"
    },
    {
      "type": "text",
      "id": "trust_2",
      "label": "Trust Badge 2",
      "default": "Cash on Delivery"
    },
    {
      "type": "text",
      "id": "trust_3",
      "label": "Trust Badge 3",
      "default": "Lens Guidance Included"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ]
}
{% endschema %}
