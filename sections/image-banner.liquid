{{ 'section-image-banner.css' | asset_url | stylesheet_tag }}

<div class="hero-wrapper">
  <div class="hero-left">
    <span class="hero-label">PAKISTAN'S TRUSTED OPTICAL STORE</span>
    <h1 class="hero-headline">Find Your Perfect<br>Pair of Glasses</h1>
    <p class="hero-subtext">
      Prescription eyewear, sunglasses &amp; blue light protection — 
      crafted for clarity and delivered across Pakistan.
    </p>
    <div class="hero-buttons">
      <a href="/collections/eyeglasses" class="btn-primary">
        Shop Eyeglasses
      </a>
      <a href="/collections/all" class="btn-secondary">
        View All Frames
      </a>
    </div>
    <div class="hero-trust">
      <span>✓ Free Delivery above Rs 3,000</span>
      <span>✓ Cash on Delivery</span>
      <span>✓ Prescription Guaranteed</span>
    </div>
  </div>
  <div class="hero-right">
    {% if section.settings.hero_image %}
      <img src="{{ section.settings.hero_image | img_url: 'master' }}" 
           alt="Zaman Optics" class="hero-image">
    {% else %}
      <div class="hero-placeholder">
        <span>Upload Hero Image<br>in Theme Editor</span>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.image-banner.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    }
  ],
  "presets": [
    {
      "name": "t:sections.image-banner.presets.name"
    }
  ]
}
{% endschema %}
