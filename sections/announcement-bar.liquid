<div class="announcement-bar" id="announcementBar">
  <div class="announcement-bar__content">
    <p class="announcement-bar__text">
      <span>{% render 'zaman-premium-icon', icon: 'delivery', size: 15 %} Delivery across Pakistan</span>
      <span>{% render 'zaman-premium-icon', icon: 'payment', size: 15 %} Secure online payments available</span>
      <span>{% render 'zaman-premium-icon', icon: 'phone', size: 15 %} Need help? Message us on WhatsApp</span>
    </p>
    <button class="announcement-bar__close" id="announcementClose" aria-label="Dismiss announcement">
      {% render 'zaman-premium-icon', icon: 'close', size: 16 %}
    </button>
  </div>
</div>
<style>
  .announcement-bar {
    background-color: #0F766E;
    border-bottom: 1px solid #E8E8E8;
  }
  .announcement-bar__content {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 40px;
    height: 38px;
    position: relative;
    max-width: 100%;
    margin: 0 auto;
  }
  .announcement-bar__text {
    margin: 0;
    padding: 0;
    font-size: 13px;
    font-weight: 500;
    color: #FFFFFF;
    text-align: center;
    line-height: 1.38;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 22px;
    flex-wrap: wrap;
  }
  .announcement-bar__text span {
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .announcement-bar__close {
    position: absolute;
    right: 40px;
    background: none;
    border: none;
    font-size: 20px;
    color: #FFFFFF;
    cursor: pointer;
    padding: 0;
    width: 20px;
    height: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }
  .announcement-bar__close:hover {
    opacity: 0.7;
  }
  .announcement-bar.hidden {
    display: none !important;
  }
  @media screen and (max-width: 749px) {
    .announcement-bar__content {
      padding: 0 16px;
    }
    .announcement-bar__text {
      font-size: 12px;
      gap: 10px;
    }
    .announcement-bar__close {
      right: 16px;
      font-size: 18px;
    }
  }
</style>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const announcementBar = document.getElementById('announcementBar');
    const closeBtn = document.getElementById('announcementClose');
    const storageKey = 'zaman-announcement-dismissed';
    if (announcementBar && closeBtn) {
      if (localStorage.getItem(storageKey) === 'true') {
        announcementBar.classList.add('hidden');
      }
      closeBtn.addEventListener('click', function() {
        announcementBar.classList.add('hidden');
        localStorage.setItem(storageKey, 'true');
      });
    }
  });
</script>
{% schema %}
{
  "name": "Announcement bar",
  "settings": [],
  "presets": [
    {
      "name": "Announcement bar"
    }
  ]
}
{% endschema %}
